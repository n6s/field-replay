def normalize_bib_text(value: str) -> str | None:
    normalized = re.sub(r"[^A-Za-z0-9]+", "", value.upper())
    if not normalized:
        return None
    normalized = normalized.replace("O", "0").replace("I", "1").replace("L", "1")
    if normalized == "PACER":
        return normalized
    if re.fullmatch(r"\d{2,4}", normalized):
        return normalized
    return None


