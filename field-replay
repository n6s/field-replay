def default_vision_output_root(
    source: ExportSource,
    default_dir_name: str,
) -> tuple[Path, str | None]:
    preferred_root = source.session_dir / default_dir_name
    if source.session_dir.exists() and os.access(source.session_dir, os.W_OK):
        return preferred_root, None
    fallback_root = Path.cwd() / f"{source.session_dir.name}-{default_dir_name}"
    reason = (
        f"session directory is not writable; using workspace output root {fallback_root}"
    )
    return fallback_root, reason


def normalize_bib_text(value: str) -> str | None:
    normalized = re.sub(r"[^A-Za-z0-9]+", "", value.upper())
    if not normalized:
        return None
    normalized = normalized.replace("O", "0").replace("I", "1").replace("L", "1")
    if normalized == "PACER":
        return normalized
    if re.fullmatch(r"\d{2,4}", normalized):
        return normalized
    return None


def normalize_detection_text(value: str) -> str | None:
    bib_like = normalize_bib_text(value)
    if bib_like:
        return bib_like

    normalized = value.strip().lower()
    if not normalized:
        return None
    normalized = re.sub(r"[\s_]+", "-", normalized)
    normalized = re.sub(r"[^a-z0-9:-]+", "", normalized)
    normalized = re.sub(r"-{2,}", "-", normalized).strip("-:")
    if not normalized or not re.search(r"[a-z]", normalized):
        return None
    return normalized


def is_bib_detection_label(value: str) -> bool:
    return normalize_bib_text(value) == value


def detection_promotion_key(
    detection: str,
    comparison_status: str | None = None,
    *,
    compare_mode: bool = False,
) -> str:
    normalized_detection = normalize_detection_text(detection)
    if not normalized_detection:
        return detection
    if is_bib_detection_label(normalized_detection):
        return normalized_detection
    if compare_mode and comparison_status:
        return f"{normalized_detection}@@{comparison_status}"
    return normalized_detection


def motion_zone_label(zone_spec: str | None) -> str:
    return zone_spec or "full frame"


def parse_motion_zone_value(
    raw_zone: str | None,
    *,
    grid_size: int = DEFAULT_MOTION_ZONE_GRID,
) -> tuple[str | None, str | None]:
    normalized = normalize_motion_zone_spec(raw_zone, grid_size)
    if (
        raw_zone
        and raw_zone.strip().lower() not in {"full", "all", "*", "none"}
        and normalized is None
    ):
        return None, f"invalid motion zone: {raw_zone!r}; expected C3 or B3:D4"
    return normalized, None


def motion_grid_column_label(index: int) -> str:
    if index < 0:
        raise ValueError("grid column index must be non-negative")
    label = ""
    current = index
    while True:
        current, remainder = divmod(current, 26)
        label = chr(ord("A") + remainder) + label
        if current == 0:
            return label
        current -= 1


def motion_grid_column_index(label: str) -> int | None:
    if not label or not label.isalpha():
        return None
    value = 0
    for char in label.upper():
        value = (value * 26) + (ord(char) - ord("A") + 1)
    return value - 1


def motion_grid_boundaries(total: int, grid_size: int = DEFAULT_MOTION_ZONE_GRID) -> list[int]:
    if grid_size < 1:
        raise ValueError("grid size must be at least 1")
    return [int(total * index / grid_size) for index in range(grid_size)] + [total]


def canonical_motion_zone_spec(
    start_col: int,
    start_row: int,
    end_col: int,
    end_row: int,
) -> str:
    start_label = f"{motion_grid_column_label(start_col)}{start_row + 1}"
    end_label = f"{motion_grid_column_label(end_col)}{end_row + 1}"
    if start_col == end_col and start_row == end_row:
        return start_label
    return f"{start_label}:{end_label}"


def parse_motion_zone_corner(
    token: str,
    grid_size: int = DEFAULT_MOTION_ZONE_GRID,
) -> tuple[int, int] | None:
    match = re.fullmatch(r"\s*([A-Za-z]+)\s*(\d+)\s*", token)
    if not match:
        return None
    column_index = motion_grid_column_index(match.group(1))
    row_index = int(match.group(2)) - 1
    if column_index is None or row_index < 0:
        return None
    if column_index >= grid_size or row_index >= grid_size:
        return None
    return column_index, row_index


def normalize_motion_zone_spec(
    value: str | None,
    grid_size: int = DEFAULT_MOTION_ZONE_GRID,
) -> str | None:
    if value is None:
        return None
    stripped = value.strip()
    if not stripped or stripped.lower() in {"full", "all", "*", "none"}:
        return None
    tokens = re.split(r"\s*[:,-]\s*|\s+", stripped)
    tokens = [token for token in tokens if token]
    if len(tokens) == 1:
        start = parse_motion_zone_corner(tokens[0], grid_size)
        end = start
    elif len(tokens) == 2:
        start = parse_motion_zone_corner(tokens[0], grid_size)
        end = parse_motion_zone_corner(tokens[1], grid_size)
    else:
        return None
    if start is None or end is None:
        return None
    start_col = min(start[0], end[0])
    start_row = min(start[1], end[1])
    end_col = max(start[0], end[0])
    end_row = max(start[1], end[1])
    return canonical_motion_zone_spec(start_col, start_row, end_col, end_row)


def motion_zone_pixel_rect(
    zone_spec: str | None,
    *,
    width: int,
    height: int,
    grid_size: int = DEFAULT_MOTION_ZONE_GRID,
) -> tuple[int, int, int, int]:
    if not zone_spec:
        return 0, 0, width, height
    normalized = normalize_motion_zone_spec(zone_spec, grid_size)
    if normalized is None:
        return 0, 0, width, height
    parts = normalized.split(":")
    start = parse_motion_zone_corner(parts[0], grid_size)
    end = parse_motion_zone_corner(parts[-1], grid_size)
    if start is None or end is None:
        return 0, 0, width, height

    x_bounds = motion_grid_boundaries(width, grid_size)
    y_bounds = motion_grid_boundaries(height, grid_size)
    x = x_bounds[start[0]]
    y = y_bounds[start[1]]
    zone_width = max(1, x_bounds[end[0] + 1] - x)
    zone_height = max(1, y_bounds[end[1] + 1] - y)
    return x, y, zone_width, zone_height


def build_motion_zone_preview_filter(
    preview_size: str = DEFAULT_MOTION_PREVIEW_SIZE,
    *,
    zone_spec: str | None = None,
    grid_size: int = DEFAULT_MOTION_ZONE_GRID,
) -> str:
    dimensions = parse_scale_dimensions(preview_size)
    if not dimensions:
        raise ValueError(
            f"invalid motion preview size: {preview_size!r}; expected WxH like 960x540"
        )
    width, height = dimensions
    x_bounds = motion_grid_boundaries(width, grid_size)
    y_bounds = motion_grid_boundaries(height, grid_size)
    filters = [scale_filter_for_dimensions(width, height)]
    if zone_spec:
        zone_x, zone_y, zone_width, zone_height = motion_zone_pixel_rect(
            zone_spec,
            width=width,
            height=height,
            grid_size=grid_size,
        )
        filters.append(
            f"drawbox=x={zone_x}:y={zone_y}:w={zone_width}:h={zone_height}:color=0x00ff0099:t=fill"
        )
    for x in x_bounds[1:-1]:
        filters.append(
            f"drawbox=x={x}:y=0:w=2:h={height}:color=0xffff00cc:t=fill"
        )
    for y in y_bounds[1:-1]:
        filters.append(
            f"drawbox=x=0:y={y}:w={width}:h=2:color=0xffff00cc:t=fill"
        )
    for row in range(grid_size):
        for col in range(grid_size):
            label = f"{motion_grid_column_label(col)}{row + 1}"
            label_x = x_bounds[col] + 12
            label_y = y_bounds[row] + 10
            filters.append(
                "drawtext="
                f"text='{ffmpeg_drawtext_escape(label)}':"
                f"x={label_x}:y={label_y}:"
                "box=1:boxcolor=0x00000099:boxborderw=8:"
                "fontcolor=white:fontsize=24:borderw=2"
            )
    return ",".join(filters)


def prompt_motion_zone_spec(
    current_zone: str | None = None,
    *,
    grid_size: int = DEFAULT_MOTION_ZONE_GRID,
) -> str | None:
    default_value = current_zone or "full"
    while True:
        raw = prompt_text(
            "Motion zone (one cell like C3, two corners like B3 D4, or full)",
            default_value,
        ).strip()
        lowered = raw.lower()
        if lowered in {"q", "quit"}:
            return current_zone
        normalized = normalize_motion_zone_spec(raw, grid_size)
        if normalized is not None or lowered in {"full", "all", "*", "none"}:
            return normalized
        print("Enter one cell like C3, two corners like B3 D4, or full.")


def maybe_select_motion_zone_interactively(
    *,
    args: argparse.Namespace,
    session_dir: Path,
    source_path: Path,
    ffmpeg_path: str,
    supported_filters: set[str],
    output_root: Path,
    force: bool = False,
) -> str | None:
    if not interactive_mode_enabled(args) or not args.motion_gate:
        return args.motion_zone
    if "drawtext" not in supported_filters or "drawbox" not in supported_filters:
        print(
            "warning: ffmpeg drawtext/drawbox filters are unavailable; cannot render motion-zone preview",
            file=sys.stderr,
        )
        return args.motion_zone
    if not force:
        default_select = args.motion_zone is None
        prompt_text_value = (
            "Select a motion zone from a preview frame now?"
            if args.motion_zone is None
            else f"Edit motion zone '{args.motion_zone}' from a preview frame now?"
        )
        if not prompt_yes_no(prompt_text_value, default=default_select):
            return args.motion_zone

    preview_path = output_root / "motion-zone-preview.jpg"
    viewer = choose_image_viewer(None)
    while True:
        duration_seconds = ffprobe_duration_seconds(source_path) or 0.0
        offset_seconds = max(duration_seconds - max(args.tail_offset, 0.0), 0.0)
        preview_filter = build_motion_zone_preview_filter(
            DEFAULT_MOTION_PREVIEW_SIZE,
            zone_spec=args.motion_zone,
            grid_size=DEFAULT_MOTION_ZONE_GRID,
        )
        extract_frame_at_time(
            ffmpeg_path,
            source_path,
            offset_seconds,
            preview_path,
            frame_filter=preview_filter,
        )
        print(f"Motion zone preview: {preview_path}")
        if viewer:
            command = build_image_viewer_command(viewer, [preview_path])
            print("Viewer:", shlex.join(command))
            launch_background_viewer(command)
        zone_spec = prompt_motion_zone_spec(args.motion_zone)
        if zone_spec == args.motion_zone:
            return zone_spec
        args.motion_zone = zone_spec


