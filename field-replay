def run_record_command(args: argparse.Namespace, *, launch_player: bool = False) -> int:
    config_path = args.config_file.expanduser()
    config = load_config(config_path)
    profiles = config.get("profiles", {})
    if not args.profile:
        last_profile = config.get("last_profile")
        if last_profile in profiles:
            args.profile = last_profile
    if args.profile:
        profile = profiles.get(args.profile)
        if not profile:
            print(f"profile not found: {args.profile}", file=sys.stderr)
            return 1
        apply_profile(args, profile)
        config["last_profile"] = args.profile

    if interactive_mode_enabled(args):
        selected_profile_name = choose_record_profile(
            config, preferred_profile=args.profile
        )
        if selected_profile_name and selected_profile_name != "__manual__":
            selected_profile = profiles[selected_profile_name]
            apply_profile(args, selected_profile)
            config["last_profile"] = selected_profile_name
            for line in profile_summary_lines(selected_profile_name, selected_profile):
                print(line)
            print()
            save_config(config_path, config)
        else:
            configure_record_interactively(args, config)
            print()
            if not prompt_yes_no("Start recording now?", default=True):
                return 0
            print()
            save_config(config_path, config)

    source_error = validate_source_args(args)
    if source_error:
        print(source_error, file=sys.stderr)
        return 1

    for warning in auto_select_video_codec_mode(args):
        print(f"warning: {warning}", file=sys.stderr)

    ffmpeg_path, supported_encoders = detect_supported_encoders(args.ffmpeg_bin)
    if not ffmpeg_path:
        print(f"ffmpeg binary not found: {args.ffmpeg_bin}", file=sys.stderr)
        return 1

    if not uses_video_passthrough(args):
        resolved_encoder = resolve_encoder(ffmpeg_path, supported_encoders, args.encoder)
        if not resolved_encoder:
            print("no supported video encoder found for this ffmpeg build", file=sys.stderr)
            return 1
        if resolved_encoder != args.encoder:
            print(
                f"warning: encoder '{args.encoder}' is unavailable; using '{resolved_encoder}' instead",
                file=sys.stderr,
            )
            args.encoder = resolved_encoder

    _, supported_filters = detect_supported_filters(args.ffmpeg_bin)
    for warning in normalize_video_settings(args, supported_filters=supported_filters):
        print(f"warning: {warning}", file=sys.stderr)
    player = None
    if launch_player:
        player = choose_player(args.player)
        if not player:
            requested = args.player or "vlc/mpv/ffplay"
            print(f"player not found: {requested}", file=sys.stderr)
            return 1

    recordings_dir = args.recordings_dir.expanduser()
    session_name = args.session_name or default_session_name(args.session_prefix)
    paths = make_session_paths(recordings_dir, session_name, args.archive_format)
    ffmpeg_command = build_ffmpeg_command(paths, args)

    if args.dry_run:
        print_session_summary(paths)
        print("FFmpeg:", shlex.join(ffmpeg_command))
        if launch_player and player:
            print(
                "Player:",
                shlex.join(
                    build_player_command(player, paths.timeshift_path, args.file_caching_ms)
                ),
            )
        return 0

    if paths.session_dir.exists():
        print(f"session directory already exists: {paths.session_dir}", file=sys.stderr)
        return 1

    ensure_directory(paths.session_dir)
    write_metadata(paths, args, ffmpeg_command, state="starting")

    try:
        lock_paths = acquire_device_locks(recordings_dir, args, session_name)
    except RuntimeError as exc:
        print(exc, file=sys.stderr)
        return 1

    print_session_summary(paths)
    print("FFmpeg:", shlex.join(ffmpeg_command))
    process = subprocess.Popen(ffmpeg_command, cwd=paths.session_dir)
    interrupted = False
    capture_started = False
    player_process = None
    try:
        capture_started = wait_for_capture_output(paths, process)
        if capture_started:
            update_latest_symlink(paths)
            config["last_recordings_dir"] = str(recordings_dir)
            config["last_session_dir"] = str(paths.session_dir)
            save_config(config_path, config)
            if launch_player and player:
                player_process = launch_background_player(
                    player, paths.timeshift_path, args.file_caching_ms
                )
        exit_code = process.wait()
    except KeyboardInterrupt:
        interrupted = True
        print("\nStopping recording...")
        process.send_signal(signal.SIGINT)
        exit_code = process.wait()
    finally:
        release_device_locks(lock_paths)

    capture_ok = exit_code == 0 or (interrupted and exit_code == 255)
    archive_ok = False
    archive_status = None
    captured_anything = has_timeshift_session(paths)

    if captured_anything:
        archive_ok, archive_status = create_archive(paths, args)
        if not capture_ok and archive_ok:
            archive_status = (
                f"{archive_status}; capture exited with code {exit_code}"
            )
    else:
        archive_status = f"capture failed with exit code {exit_code}"

    final_state = "finished" if capture_ok and archive_ok else "partial"
    write_metadata(
        paths,
        args,
        ffmpeg_command,
        state=final_state,
        exit_code=exit_code,
        archive_status=archive_status,
    )

    if capture_ok:
        return 0 if archive_ok else 1
    return 1 if archive_ok else exit_code


def run_offline_vision_scan(
    *,
    source: ExportSource,
    ffmpeg_path: str,
    model: str,
    ollama_host: str,
    prompt: str,
    timeout_seconds: float,
    keepalive: str,
    repeat_cooldown_seconds: float,
    compare_frames: bool = False,
    output_root: Path,
    sample_points: Sequence[float],
    annotate_frames: bool,
    frame_filter: str | None = None,
    dry_run: bool = False,
) -> int:
    runtime_paths = vision_output_paths(output_root)
    for key in ("root", "frames_dir"):
        ensure_directory(runtime_paths[key])
    for key in (
        "events_jsonl",
        "events_log",
        "debug_log",
        "scratch_frame",
        "previous_scratch_frame",
    ):
        try:
            runtime_paths[key].unlink()
        except FileNotFoundError:
            pass

    print(f"Vision scan source: {source.source_path}")
    print(f"Vision output dir:  {output_root}")
    print(f"Vision model:       {model}")
    print(f"Samples:            {len(sample_points)}")
    print(f"Repeat cooldown:    {repeat_cooldown_seconds:.0f}s")
    print(f"Compare:            {'previous frame' if compare_frames else 'disabled'}")
    if frame_filter:
        print(f"Frame filter:       {frame_filter}")
    if dry_run:
        for offset_seconds in sample_points:
            print(f"  sample {format_duration(offset_seconds)}")
        return 0

    last_promoted_by_key: dict[str, float] = {}
    previous_sample_frame = runtime_paths["previous_scratch_frame"]
    for offset_seconds in sample_points:
        try:
            extract_frame_at_time(
                ffmpeg_path,
                source.source_path,
                offset_seconds,
                runtime_paths["scratch_frame"],
                frame_filter=frame_filter,
            )
            process_vision_frame(
                runtime_paths=runtime_paths,
                session_dir=source.session_dir,
                frame_path=runtime_paths["scratch_frame"],
                ffmpeg_bin=ffmpeg_path,
                annotate_frames=annotate_frames,
                offset_seconds=offset_seconds,
                model=model,
                ollama_host=ollama_host,
                prompt=(
                    comparison_vision_prompt(prompt)
                    if compare_frames and previous_sample_frame.exists()
                    else single_frame_vision_prompt(prompt)
                ),
                timeout_seconds=timeout_seconds,
                keepalive=keepalive,
                repeat_cooldown_seconds=repeat_cooldown_seconds,
                last_promoted_by_key=last_promoted_by_key,
            )
            if compare_frames:
                shutil.copy2(runtime_paths["scratch_frame"], previous_sample_frame)
        except RuntimeError as exc:
            append_jsonl(
                runtime_paths["debug_log"],
                {
                    "w": event_wall_time(datetime.now().astimezone()),
                    "t": round(offset_seconds, 1),
                    "frame": relative_to_session(
                        runtime_paths["scratch_frame"], source.session_dir
                    ),
                    "error": str(exc),
                },
            )

    print(f"Vision events:      {runtime_paths['events_log']}")
    print(f"Vision debug:       {runtime_paths['debug_log']}")
    return 0


