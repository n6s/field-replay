def resolve_export_encoder(
    ffmpeg_path: str | None, supported_encoders: set[str], session_metadata: dict
) -> tuple[str | None, str, str]:
    session_encoder = session_metadata.get("encoder")
    session_preset = str(session_metadata.get("preset") or "fast")
    if (
        ffmpeg_path
        and session_encoder
        and session_encoder in supported_encoders
        and encoder_smoke_test(ffmpeg_path, session_encoder)
    ):
        return session_encoder, session_preset, "matched session encoder"
    if ffmpeg_path and "h264_nvenc" in supported_encoders and encoder_smoke_test(
        ffmpeg_path, "h264_nvenc"
    ):
        return "h264_nvenc", "fast", "hardware export encoder available"
    if ffmpeg_path and "libx264" in supported_encoders and encoder_smoke_test(
        ffmpeg_path, "libx264"
    ):
        return "libx264", "medium", "software export fallback"
    fallback = None
    for candidate in ("h264_vaapi", "h264_v4l2m2m", "mpeg4"):
        if ffmpeg_path and candidate in supported_encoders and encoder_smoke_test(
            ffmpeg_path, candidate
        ):
            fallback = candidate
            break
    if fallback:
        default_preset = "fast" if fallback.startswith("h264_") else "medium"
        return fallback, default_preset, "best available fallback"
    return None, "medium", "no supported export encoder"


def build_export_command(
    ffmpeg_bin: str,
    source_path: Path,
    output_path: Path,
    preset_name: str,
    video_encoder: str,
    encoder_preset: str,
    timelapse_spec: TimelapseSpec | None = None,
) -> list[str]:
    preset = EXPORT_PRESETS[preset_name]
    video_bitrate_mbps = preset["video_bitrate_mbps"]
    audio_bitrate_kbps = preset["audio_bitrate_kbps"]
    maxrate_mbps = max(video_bitrate_mbps * 4 / 3, video_bitrate_mbps)
    bufsize_mbps = maxrate_mbps * 2
    command = [
        ffmpeg_bin,
        "-hide_banner",
        "-stats",
        "-y",
    ]
    if timelapse_spec:
        command.extend(["-fflags", "+genpts"])
    command.extend(["-i", str(source_path)])
    video_filters = []
    if timelapse_spec:
        video_filters.extend(
            [
                f"select='not(mod(n\\,{timelapse_spec.frame_skip}))'",
                "settb=AVTB",
                f"setpts=N/({timelapse_spec.output_fps:g}*TB)",
                f"fps={timelapse_spec.output_fps:g}",
            ]
        )
    if preset["scale"]:
        video_filters.append(f"scale={preset['scale']}")
    if video_filters:
        command.extend(["-vf", ",".join(video_filters)])
    command.extend(
        [
            "-c:v",
            video_encoder,
            "-preset",
            encoder_preset,
            "-b:v",
            f"{video_bitrate_mbps:g}M",
            "-maxrate",
            f"{maxrate_mbps:g}M",
            "-bufsize",
            f"{bufsize_mbps:g}M",
            "-pix_fmt",
            "yuv420p",
        ]
    )
    if timelapse_spec:
        command.extend(["-an", "-fps_mode", "cfr", "-avoid_negative_ts", "make_zero"])
    else:
        command.extend(
            [
                "-c:a",
                "aac",
                "-b:a",
                f"{audio_bitrate_kbps}k",
            ]
        )
    command.extend(["-movflags", "+faststart", str(output_path)])
    return command


def preset_total_mbps(
    preset_name: str, timelapse_spec: TimelapseSpec | None = None
) -> float:
    preset = EXPORT_PRESETS[preset_name]
    if timelapse_spec:
        return preset["video_bitrate_mbps"]
    return preset["video_bitrate_mbps"] + (preset["audio_bitrate_kbps"] / 1000.0)


def export_preset_label(
    preset_name: str,
    duration_seconds: float | None,
    timelapse_spec: TimelapseSpec | None = None,
) -> str:
    preset = EXPORT_PRESETS[preset_name]
    total_mbps = preset_total_mbps(preset_name, timelapse_spec)
    estimated_size = estimate_size_bytes(duration_seconds, total_mbps)
    estimate_label = (
        format_bytes(estimated_size)
        if estimated_size is not None
        else f"~{total_mbps:.2f} Mbps"
    )
    return f"{preset['label']} - {preset['quality_hint']}, about {estimate_label}"


def choose_export_preset(
