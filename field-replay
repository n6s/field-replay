def video_size_label(video_size: str | None) -> str:
    if not video_size or "x" not in video_size:
        return "video"
    try:
        width_text, height_text = video_size.lower().split("x", 1)
        width = int(width_text)
        height = int(height_text)
    except ValueError:
        return video_size.replace("x", "x")
    if width == 1280 and 700 <= height <= 740:
        return "720p"
    if width == 1920 and 1040 <= height <= 1100:
        return "1080p"
    if width == 3840 and 2100 <= height <= 2200:
        return "2160p"
    return f"{width}x{height}"


def export_resolution_label(preset_name: str, session_metadata: dict) -> str:
    if EXPORT_PRESETS[preset_name]["scale"]:
