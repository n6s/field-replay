def sighting_span_seconds(matches: Sequence[dict]) -> float:
    if len(matches) < 2:
        return 0.0
    try:
        first_time = float(matches[0].get("t") or 0.0)
        last_time = float(matches[-1].get("t") or 0.0)
    except (TypeError, ValueError):
        return 0.0
    return max(last_time - first_time, 0.0)


def bib_match_summary_lines(session_dir: Path, bib: str, matches: Sequence[dict]) -> list[str]:
    first_match = matches[0]
    last_match = matches[-1]
    lines = [
        f"Session:   {session_dir}",
        f"Bib:       {bib}",
        f"Matches:   {len(matches)}",
        f"First:     {first_match.get('w', '?')} ({format_duration(first_match.get('t'))})",
        f"Last:      {last_match.get('w', '?')} ({format_duration(last_match.get('t'))})",
    ]
    span_seconds = sighting_span_seconds(matches)
    if span_seconds >= 60.0:
        lines.append(f"Span:      {format_duration(span_seconds)}")
    return lines


