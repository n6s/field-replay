    ensure_directory(output_root)
    config["last_session_dir"] = str(source.session_dir)
    save_config(config_path, config)

    duration_seconds = probe_media_duration(args.ffmpeg_bin, source.source_path) or 0.0
    sample_points = media_sample_points(duration_seconds, args.sample_interval)
    if args.max_samples is not None:
        sample_points = sample_points[: max(args.max_samples, 0)]
    prompt = args.prompt or default_vision_prompt()

    print(f"Vision sweep source: {source.source_path}")
    print(f"Vision sweep dir:    {output_root}")
    print(f"Vision model:        {args.model}")
    print(f"Samples:             {len(sample_points)}")
    print(f"Variants:            {', '.join(variant.label for variant in variants)}")
    if args.dry_run:
        for variant in variants:
            print(f"  variant {variant.label} -> {output_root / variant.output_slug}")
        for offset_seconds in sample_points:
            print(f"  sample {format_duration(offset_seconds)}")
        return 0

    results: list[dict] = []
    reference_summary: dict | None = None
    for index, variant in enumerate(variants):
        variant_output_root = output_root / variant.output_slug
        print()
        print(f"[{index + 1}/{len(variants)}] Scanning {variant.label}")
        run_offline_vision_scan(
            source=source,
            ffmpeg_path=ffmpeg_path,
            model=args.model,
            ollama_host=args.ollama_host,
            prompt=prompt,
            timeout_seconds=args.timeout,
            keepalive=args.keepalive,
