                ollama_host=args.ollama_host,
                prompt=prompt,
                timeout_seconds=args.timeout,
                keepalive=args.keepalive,
                repeat_cooldown_seconds=args.repeat_cooldown,
                last_promoted_by_bib=last_promoted_by_bib,
            )
        except RuntimeError as exc:
            append_jsonl(
                runtime_paths["debug_log"],
                {
                    "w": event_wall_time(datetime.now().astimezone()),
                    "t": round(offset_seconds, 1),
                    "frame": relative_to_session(
                        runtime_paths["scratch_frame"], source.session_dir
                    ),
                    "error": str(exc),
                },
            )

    print(f"Vision events:      {runtime_paths['events_log']}")
    print(f"Vision debug:       {runtime_paths['debug_log']}")
    return 0


def command_vision_live(args: argparse.Namespace) -> int:
    config_path = args.config_file.expanduser()
    config = load_config(config_path)
    if not args.session_dir and interactive_mode_enabled(args):
        selected_target = select_session_target(
            args,
            config,
            title="Choose a session for live vision",
        )
        if not selected_target:
            print("no sessions found for live vision", file=sys.stderr)
            return 1
        args.session_dir = Path(selected_target)

    try:
        session_dir = resolve_session_dir(
            args.recordings_dir.expanduser(),
            str(args.session_dir) if args.session_dir else None,
        )
    except FileNotFoundError as exc:
        print(exc, file=sys.stderr)
        return 1

    ffmpeg_path = shutil.which(args.ffmpeg_bin)
    if not ffmpeg_path:
        print(f"ffmpeg binary not found: {args.ffmpeg_bin}", file=sys.stderr)
        return 1
    _, supported_filters = detect_supported_filters(args.ffmpeg_bin)
    annotate_frames = "drawtext" in supported_filters
    if not annotate_frames:
        print(
            "warning: ffmpeg drawtext filter is unavailable; saving raw promoted frames",
            file=sys.stderr,
        )

    output_root = session_dir / "vision-live"
    runtime_paths = vision_output_paths(output_root)
    for key in ("root", "frames_dir"):
        ensure_directory(runtime_paths[key])
    try:
        runtime_paths["scratch_frame"].unlink()
    except FileNotFoundError:
        pass

    config["last_session_dir"] = str(session_dir)
    save_config(config_path, config)

    prompt = args.prompt or default_vision_prompt()
    timeshift_path = session_dir / DEFAULT_TIMESHIFT_NAME
    processed_offsets: set[float] = set()
    sample_count = 0
    last_promoted_by_bib: dict[str, float] = {}

    print(f"Vision live session: {session_dir}")
    print(f"Vision output dir:   {output_root}")
    print(f"Vision model:        {args.model}")
    print(f"Repeat cooldown:     {args.repeat_cooldown:.0f}s")
    print("Sampling is model-paced; press Ctrl+C to stop.")

    while True:
        if args.max_samples is not None and sample_count >= args.max_samples:
            return 0
        if not timeshift_path.exists() or timeshift_path.stat().st_size == 0:
            if args.once:
                return 0
            time.sleep(args.idle_sleep)
            continue

        duration_seconds = ffprobe_duration_seconds(timeshift_path)
        if duration_seconds is None or duration_seconds <= 0:
            if args.once:
                return 0
            time.sleep(args.idle_sleep)
            continue

        offset_seconds = max(duration_seconds - max(args.tail_offset, 0.0), 0.0)
        rounded_offset = round(offset_seconds, 1)
        if rounded_offset in processed_offsets:
            if args.once:
                return 0
            time.sleep(args.idle_sleep)
            continue

        try:
            extract_frame_at_time(
                ffmpeg_path,
                timeshift_path,
                offset_seconds,
                runtime_paths["scratch_frame"],
            )
            promoted = process_vision_frame(
                runtime_paths=runtime_paths,
                session_dir=session_dir,
                frame_path=runtime_paths["scratch_frame"],
                ffmpeg_bin=ffmpeg_path,
                annotate_frames=annotate_frames,
                offset_seconds=offset_seconds,
                model=args.model,
                ollama_host=args.ollama_host,
                prompt=prompt,
                timeout_seconds=args.timeout,
                keepalive=args.keepalive,
                repeat_cooldown_seconds=args.repeat_cooldown,
                last_promoted_by_bib=last_promoted_by_bib,
            )
            for payload in promoted:
                print(vision_event_log_line(payload), flush=True)
            processed_offsets.add(rounded_offset)
            sample_count += 1
        except RuntimeError as exc:
            append_jsonl(
                runtime_paths["debug_log"],
                {
                    "w": event_wall_time(datetime.now().astimezone()),
                    "t": rounded_offset,
                    "frame": relative_to_session(runtime_paths["scratch_frame"], session_dir),
                    "error": str(exc),
                },
            )
            if args.once:
                return 1


