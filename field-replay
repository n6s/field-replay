            ):
                vision_profiles[active_vision_profile_name]["motion_zone"] = args.motion_zone
                config["vision_profiles"] = vision_profiles
                save_config(config_path, config)
        applied_update, updated_zone = apply_runtime_motion_zone_update(
            runtime_paths,
            current_zone=args.motion_zone,
        )
        if applied_update:
            args.motion_zone = updated_zone
    write_vision_runtime_state(
        runtime_paths,
        vision_profile=active_vision_profile_name,
        sample_interval=args.sample_interval,
        motion_gate=args.motion_gate,
        compare_frames=args.compare_frames,
        motion_size=args.motion_size,
        motion_zone=args.motion_zone,
        motion_threshold=args.motion_threshold,
        motion_min_changed_pct=args.motion_min_changed_pct,
        motion_consecutive=args.motion_consecutive,
        motion_hold=args.motion_hold,
    )
    timeshift_path = session_dir / DEFAULT_TIMESHIFT_NAME
    processed_offsets: set[float] = set()
    sample_count = 0
    last_promoted_by_key: dict[str, float] = {}
    previous_motion_frame: bytes | None = None
    consecutive_motion_hits = 0
    gate_open_until: float | None = None
    pending_skip_markers = 0
    last_runtime_control_mtime = (
        runtime_paths["runtime_control"].stat().st_mtime
        if runtime_paths["runtime_control"].exists()
        else None
    )

    def flush_skip_markers() -> None:
        nonlocal pending_skip_markers
        if pending_skip_markers:
            print()
            pending_skip_markers = 0

    print(f"Vision live: {session_dir}")
    print(f"Output:      {output_root}")
    print(f"Model:       {args.model}")
    print(f"Cadence:     {args.sample_interval:g}s, {args.tail_offset:g}s behind live")
    print(f"Cooldown:    {args.repeat_cooldown:.0f}s")
    print(f"Compare:     {'previous frame' if args.compare_frames else 'disabled'}")
    if args.motion_gate:
        print(
            "Motion:      "
            f"{args.motion_size}, zone={motion_zone_label(args.motion_zone)}, "
            f"mean>={args.motion_threshold:g}, "
            f"changed>={args.motion_min_changed_pct:g}%, "
            f"hits>={args.motion_consecutive}, hold={args.motion_hold:g}s"
        )
        if args.motion_zone is None:
            print(
                "Hint: use `field-replay motion-zone` to save a tighter motion zone later. Running full-frame for now."
            )
    else:
        print("Motion:      disabled")
    if args.verbose:
        print("Verbose:     printing per-sample diagnostics")
    print("Promoted sightings will appear below. Press Ctrl+C to stop.")

    while True:
        if args.max_samples is not None and sample_count >= args.max_samples:
            return 0
        if not timeshift_path.exists() or timeshift_path.stat().st_size == 0:
            if args.once:
                return 0
            time.sleep(args.idle_sleep)
            continue

        duration_seconds = ffprobe_duration_seconds(timeshift_path)
        if duration_seconds is None or duration_seconds <= 0:
            if args.once:
                return 0
            time.sleep(args.idle_sleep)
            continue

        offset_seconds = live_sample_offset(
            duration_seconds,
            tail_offset=args.tail_offset,
            sample_interval=args.sample_interval,
        )
        rounded_offset = round(offset_seconds, 1)
        if rounded_offset in processed_offsets:
            if args.once:
                return 0
            time.sleep(args.idle_sleep)
            continue

        try:
            motion_result = MotionSampleResult(
                enabled=False,
                mean_diff=None,
                changed_pct=None,
                triggered=True,
                gate_open=True,
                reason="disabled",
            )
            motion_gate_open = True
            if args.motion_gate:
                control_mtime = (
                    runtime_paths["runtime_control"].stat().st_mtime
                    if runtime_paths["runtime_control"].exists()
                    else None
                )
                if control_mtime != last_runtime_control_mtime:
                    last_runtime_control_mtime = control_mtime
                    applied_update, updated_zone = apply_runtime_motion_zone_update(
                        runtime_paths,
                        current_zone=args.motion_zone,
                    )
                    if applied_update:
                        flush_skip_markers()
                        args.motion_zone = updated_zone
                        previous_motion_frame = None
                        consecutive_motion_hits = 0
                        gate_open_until = None
                        write_vision_runtime_state(
                            runtime_paths,
                            vision_profile=active_vision_profile_name,
                            sample_interval=args.sample_interval,
                            motion_gate=args.motion_gate,
                            compare_frames=args.compare_frames,
                            motion_size=args.motion_size,
                            motion_zone=args.motion_zone,
                            motion_threshold=args.motion_threshold,
                            motion_min_changed_pct=args.motion_min_changed_pct,
                            motion_consecutive=args.motion_consecutive,
                            motion_hold=args.motion_hold,
                        )
                        print(
                            "[vision-live] "
                            f"updated motion zone to {motion_zone_label(args.motion_zone)}",
                            flush=True,
                        )
                current_motion_frame = extract_motion_plane_at_time(
                    ffmpeg_path,
                    timeshift_path,
                    offset_seconds,
                    motion_size=args.motion_size,
                    motion_zone=args.motion_zone,
                    motion_zone_grid=DEFAULT_MOTION_ZONE_GRID,
                )
                motion_result = evaluate_motion_gate(
                    enabled=True,
                    previous_frame=previous_motion_frame,
                    current_frame=current_motion_frame,
                    mean_threshold=args.motion_threshold,
                    min_changed_pct=args.motion_min_changed_pct,
                )
                previous_motion_frame = current_motion_frame
                if motion_result.triggered:
                    consecutive_motion_hits += 1
                else:
                    consecutive_motion_hits = 0
                if consecutive_motion_hits >= max(args.motion_consecutive, 1):
                    gate_open_until = offset_seconds + max(args.motion_hold, 0.0)
                motion_gate_open = (
                    gate_open_until is not None
                    and offset_seconds <= gate_open_until + 0.001
                )
                motion_result = MotionSampleResult(
                    enabled=True,
                    mean_diff=motion_result.mean_diff,
                    changed_pct=motion_result.changed_pct,
                    triggered=motion_result.triggered,
                    gate_open=motion_gate_open,
                    reason=motion_result.reason,
                )

            if args.motion_gate and not motion_gate_open:
                append_jsonl(
                    runtime_paths["debug_log"],
                    {
                        "w": event_wall_time(datetime.now().astimezone()),
                        "t": round(offset_seconds, 1),
                        "frame": None,
                        "motion_gate": {
                            "enabled": True,
                            "size": args.motion_size,
                            "zone": args.motion_zone,
                            "mean_diff": (
                                round(motion_result.mean_diff, 3)
                                if motion_result.mean_diff is not None
                                else None
                            ),
                            "changed_pct": (
                                round(motion_result.changed_pct, 3)
                                if motion_result.changed_pct is not None
                                else None
                            ),
                            "triggered": motion_result.triggered,
                            "gate_open": False,
                            "reason": motion_result.reason,
                            "consecutive_hits": consecutive_motion_hits,
                            "hold_until": (
                                round(gate_open_until, 3)
                                if gate_open_until is not None
                                else None
                            ),
                        },
                        "skipped_reason": "motion-gate-closed",
                    },
                )
                if args.verbose:
                    print(".", end="", flush=True)
                    pending_skip_markers += 1
                    if pending_skip_markers >= 80:
                        print()
                        pending_skip_markers = 0
                processed_offsets.add(rounded_offset)
                sample_count += 1
                if args.once:
                    flush_skip_markers()
                    return 0
                continue

            extract_frame_at_time(
                ffmpeg_path,
                timeshift_path,
                offset_seconds,
                runtime_paths["scratch_frame"],
                frame_filter=frame_filter,
            )
            if args.verbose:
                flush_skip_markers()
                print(
                    f"[vision-live] analyzing {format_duration(offset_seconds)} with {args.model} "
                    f"({motion_summary_text(motion_result)})...",
                    flush=True,
                )
            comparison_frame_path = (
                runtime_paths["previous_scratch_frame"]
                if args.compare_frames and runtime_paths["previous_scratch_frame"].exists()
                else None
            )
            prompt = (
                comparison_vision_prompt(base_prompt)
                if comparison_frame_path is not None
                else single_frame_vision_prompt(base_prompt)
            )
            result = process_vision_frame(
                runtime_paths=runtime_paths,
                session_dir=session_dir,
                frame_path=runtime_paths["scratch_frame"],
                comparison_frame_path=comparison_frame_path,
                ffmpeg_bin=ffmpeg_path,
                annotate_frames=annotate_frames,
                offset_seconds=offset_seconds,
                model=args.model,
                ollama_host=args.ollama_host,
                prompt=prompt,
                timeout_seconds=args.timeout,
                keepalive=args.keepalive,
                repeat_cooldown_seconds=args.repeat_cooldown,
                last_promoted_by_key=last_promoted_by_key,
            )
            if args.compare_frames:
                shutil.copy2(
                    runtime_paths["scratch_frame"],
                    runtime_paths["previous_scratch_frame"],
                )
            if args.motion_gate:
                append_jsonl(
                    runtime_paths["debug_log"],
                    {
                        "w": event_wall_time(datetime.now().astimezone()),
                        "t": round(offset_seconds, 1),
                        "frame": relative_to_session(
                            runtime_paths["scratch_frame"], session_dir
                        ),
                        "motion_gate": {
                            "enabled": True,
                            "size": args.motion_size,
                            "zone": args.motion_zone,
                            "mean_diff": (
                                round(motion_result.mean_diff, 3)
                                if motion_result.mean_diff is not None
                                else None
                            ),
                            "changed_pct": (
                                round(motion_result.changed_pct, 3)
                                if motion_result.changed_pct is not None
                                else None
                            ),
                            "triggered": motion_result.triggered,
                            "gate_open": motion_result.gate_open,
                            "reason": motion_result.reason,
                            "consecutive_hits": consecutive_motion_hits,
                            "hold_until": (
                                round(gate_open_until, 3)
                                if gate_open_until is not None
                                else None
                            ),
                        },
                    },
                )
            if result.error:
                flush_skip_markers()
                print(
                    f"[vision-live] {format_duration(offset_seconds)} error after {result.elapsed_ms} ms: {result.error}",
                    flush=True,
                )
            elif result.promoted:
                if args.verbose:
                    flush_skip_markers()
                    print(
                        "[vision-live] "
                        f"{format_duration(offset_seconds)} promoted "
                        f"{', '.join(event_detection_label(payload) or '?' for payload in result.promoted)} "
                        f"in {result.elapsed_ms} ms",
                        flush=True,
                    )
            elif args.verbose:
                flush_skip_markers()
                detected = ", ".join(result.detections) if result.detections else "nothing"
                suppressed = (
                    f"; suppressed unchanged {', '.join(result.unchanged_suppressed)}"
                    if result.unchanged_suppressed
                    else ""
                )
                print(
                    f"[vision-live] {format_duration(offset_seconds)} saw {detected}{suppressed} in {result.elapsed_ms} ms",
                    flush=True,
                )
            for payload in result.promoted:
                print(vision_event_log_line(payload), flush=True)
            processed_offsets.add(rounded_offset)
            sample_count += 1
            if args.once:
                flush_skip_markers()
                return 0
        except RuntimeError as exc:
            append_jsonl(
                runtime_paths["debug_log"],
                {
                    "w": event_wall_time(datetime.now().astimezone()),
                    "t": rounded_offset,
                    "frame": relative_to_session(runtime_paths["scratch_frame"], session_dir),
                    "error": str(exc),
                },
            )
            flush_skip_markers()
            print(
                f"[vision-live] {format_duration(rounded_offset)} error: {exc}",
                file=sys.stderr,
                flush=True,
            )
            if args.once:
                return 1


def command_motion_zone(args: argparse.Namespace) -> int:
    config_path = args.config_file.expanduser()
    config = load_config(config_path)
    vision_profiles = config.get("vision_profiles", {})

    if not args.session_dir and interactive_mode_enabled(args):
        selected_target = select_session_target(
            args,
            config,
            title="Choose a session to tune motion zone",
        )
        if not selected_target:
            print("no sessions found for motion zone tuning", file=sys.stderr)
            return 1
        args.session_dir = Path(selected_target)

    try:
        session_dir = resolve_session_dir(
            args.recordings_dir.expanduser(),
            str(args.session_dir) if args.session_dir else None,
        )
    except FileNotFoundError as exc:
        print(exc, file=sys.stderr)
        return 1

    source = export_source_for_session(session_dir)
    if not source:
        print(f"no exportable media found under {session_dir}", file=sys.stderr)
        return 1

    ffmpeg_path = shutil.which(args.ffmpeg_bin)
    if not ffmpeg_path:
        print(f"ffmpeg binary not found: {args.ffmpeg_bin}", file=sys.stderr)
        return 1
    _, supported_filters = detect_supported_filters(args.ffmpeg_bin)

    output_root = session_dir / "vision-live"
    runtime_paths = vision_output_paths(output_root)
    ensure_directory(runtime_paths["root"])

    runtime_state = load_json_file(runtime_paths["runtime_state"])
    current_zone = None
    if "motion_zone" in runtime_state:
        current_zone, _ = parse_motion_zone_value(runtime_state.get("motion_zone"))
    if runtime_paths["runtime_control"].exists():
        _, current_zone = apply_runtime_motion_zone_update(
            runtime_paths,
            current_zone=current_zone,
        )

    if args.motion_zone is not None:
        current_zone, zone_error = parse_motion_zone_value(args.motion_zone)
        if zone_error:
            print(zone_error, file=sys.stderr)
            return 1
    elif interactive_mode_enabled(args):
        selector_args = argparse.Namespace(
            interactive=args.interactive,
            motion_gate=True,
            motion_zone=current_zone,
            tail_offset=args.tail_offset,
        )
        current_zone = maybe_select_motion_zone_interactively(
            args=selector_args,
            session_dir=session_dir,
            source_path=source.source_path,
            ffmpeg_path=ffmpeg_path,
            supported_filters=supported_filters,
            output_root=output_root,
            force=True,
        )
    else:
        print(
            "motion-zone requires --motion-zone when interactive prompts are disabled",
            file=sys.stderr,
        )
        return 1

    if not write_vision_runtime_control(runtime_paths, motion_zone=current_zone):
        return 1

    config["last_session_dir"] = str(session_dir)
    save_config(config_path, config)

    print(f"Session:            {session_dir}")
    print(f"Motion zone:        {motion_zone_label(current_zone)}")
    print(f"Runtime control:    {runtime_paths['runtime_control']}")

    active_profile_name = runtime_state.get("vision_profile")
    if (
        isinstance(active_profile_name, str)
        and active_profile_name in vision_profiles
        and interactive_mode_enabled(args)
        and prompt_yes_no(
            f"Update saved vision profile '{active_profile_name}' with this motion zone?",
            default=True,
        )
    ):
        vision_profiles[active_profile_name]["motion_zone"] = current_zone
        config["vision_profiles"] = vision_profiles
        save_config(config_path, config)
        print(f"Updated vision profile: {active_profile_name}")

    print(
        "If `vision-live` is already running for this session, it will pick up the new zone on its next sample."
    )
    return 0


def command_find_bib(args: argparse.Namespace) -> int:
    config_path = args.config_file.expanduser()
    config = load_config(config_path)
    if not args.target and interactive_mode_enabled(args):
        selected_target = select_session_target(
            args, config, title="Choose a session for evidence lookup"
        )
        if not selected_target:
            print("no sessions found for evidence lookup", file=sys.stderr)
            return 1
        args.target = Path(selected_target)

    try:
        session_dir = resolve_session_dir(
            args.recordings_dir.expanduser(),
            str(args.target) if args.target else None,
        )
    except FileNotFoundError as exc:
        print(exc, file=sys.stderr)
        return 1

    config["last_session_dir"] = str(session_dir)
    save_config(config_path, config)

    normalized_label = normalize_detection_text(args.bib)
    if not normalized_label:
        print(f"not a detection-like lookup value: {args.bib}", file=sys.stderr)
        return 1

    if not evidence_event_sources_for_session(session_dir):
        print(f"no evidence event logs found under {session_dir}", file=sys.stderr)
        return 1

    matches = load_evidence_matches_for_label(session_dir, normalized_label)
    if not matches:
        print(
            f"no evidence events found for {normalized_label} in {session_dir}",
            file=sys.stderr,
        )
        return 1

    for line in label_match_summary_lines(session_dir, normalized_label, matches):
        print(line)
    print()
    print("Evidence")
    for match in matches[-args.limit :]:
        print(
            f"  {match.get('w', '?')}  "
            f"t={format_duration(match.get('t'))}  "
            f"conf={event_confidence_label(match)}  "
            f"src={match.get('_source', '?')}  "
            f"frame={match.get('f', '-')}"
        )
    return 0


def run_review_bib_action(
    *,
    args: argparse.Namespace,
    session_dir: Path,
    normalized_bib: str,
    matches: Sequence[dict],
    mode: str,
) -> int:
    if mode == "summary":
        print("Evidence")
        for match in matches[-args.limit :]:
            print(
                f"  {match.get('w', '?')}  "
                f"t={format_duration(match.get('t'))}  "
                f"conf={event_confidence_label(match)}  "
                f"src={match.get('_source', '?')}  "
                f"frame={match.get('f', '-')}"
            )
        return 0

    if mode in {"video-last", "video-first", "video-best"}:
        chosen_match = (
            matches[-1]
            if mode == "video-last"
            else matches[0]
        )
        player = choose_player(args.player)
        if not player:
            requested = args.player or "vlc/mpv/ffplay"
            print(f"player not found: {requested}", file=sys.stderr)
            return 1
        try:
            target_path = resolve_watch_target(
                args.recordings_dir.expanduser(), str(session_dir)
            )
        except FileNotFoundError as exc:
            print(exc, file=sys.stderr)
            return 1
        start_seconds = max(float(chosen_match.get("t") or 0.0) - args.pre_roll, 0.0)
        command = build_player_command(
            player,
            target_path,
            args.file_caching_ms,
            start_seconds=start_seconds,
        )
        action_label = "last sighting" if mode == "video-last" else "first sighting"
        print(
            f"Opening {action_label} for {normalized_bib} at "
            f"{format_duration(start_seconds)}"
        )
        print("Player:", shlex.join(command))
        if args.dry_run:
            return 0
        return subprocess.call(command)

    if mode == "frames":
        image_paths: list[Path] = []
        seen_paths: set[Path] = set()
        for match in matches:
            image_path = session_asset_path(session_dir, str(match.get("f") or ""))
            if image_path is None or not image_path.exists() or image_path in seen_paths:
                continue
            seen_paths.add(image_path)
            image_paths.append(image_path)
        if not image_paths:
            print(
                f"no saved frames found for {normalized_bib}",
                file=sys.stderr,
            )
            return 0
        viewer = choose_image_viewer(args.image_viewer)
        if not viewer:
            requested = args.image_viewer or "eog"
            print(f"image viewer not found: {requested}", file=sys.stderr)
            return 1
        viewer_image_paths = image_paths
        launch_in_background = False
        if normalized_bib == "all":
            viewer_image_paths = image_paths[:1]
            launch_in_background = True
            print(
                f"Opening the full promoted frame collection from the first frame "
                f"for {normalized_bib}"
            )
        else:
            print(
                f"Opening {len(image_paths)} frame"
                f"{'' if len(image_paths) == 1 else 's'} for {normalized_bib}"
            )
        command = build_image_viewer_command(viewer, viewer_image_paths)
        print("Viewer:", shlex.join(command))
        if args.dry_run:
            return 0
        if launch_in_background:
            launch_background_viewer(command)
            return 0
        return subprocess.call(command)

    print(f"unknown review mode: {mode}", file=sys.stderr)
    return 1


def prompt_review_bib_value(current_bib: str | None = None) -> str | None:
    while True:
        prompt = "Bib number, detection label, or all"
        if current_bib:
            prompt += f" [{current_bib}]"
        prompt += " (q to quit): "
        raw = input(prompt).strip()
        if not raw and current_bib:
            return current_bib
        if raw.lower() in {"q", "quit"}:
            return None
        if raw:
            return raw
        print("Enter a bib number, detection label, all, or q to quit.")


def prompt_review_action_or_bib(
    options: Sequence[tuple[str, str]],
    default_value: str | None = None,
) -> str | None:
    print("Review action")
    default_index = None
    for index, (value, label) in enumerate(options, start=1):
        marker = ""
        if value == default_value:
            default_index = index
            marker = " [default]"
        print(f"  {index}. {label}{marker}")
    print("  q. Quit")

    while True:
        prompt = "Select an option"
        if default_index is not None:
            prompt += f" [{default_index}]"
        prompt += ", or enter another label: "
        raw = input(prompt).strip()
        if not raw and default_index is not None:
            return options[default_index - 1][0]
        if raw.lower() in {"q", "quit"}:
            return None
        if raw.isdigit():
            selected = int(raw)
            if 1 <= selected <= len(options):
                return options[selected - 1][0]
        if raw:
            return f"lookup:{raw}"
        print("Enter a menu number, another label, all, or q to quit.")


def command_review_bib(args: argparse.Namespace) -> int:
    session_dir = resolve_evidence_session_from_args(args, "evidence review")
    if session_dir is None:
        return 1

    if not evidence_event_sources_for_session(session_dir):
        print(f"no evidence event logs found under {session_dir}", file=sys.stderr)
        return 1

    mode = args.mode
    if mode == "interactive" and interactive_mode_enabled(args):
        current_bib = args.bib
        skip_bib_prompt = False
        print(f"Review session: {session_dir}")
        print()
        while True:
            if skip_bib_prompt and current_bib:
                selected_bib = current_bib
                skip_bib_prompt = False
            else:
                selected_bib = prompt_review_bib_value(current_bib)
            if selected_bib is None:
                return 0
            current_bib = selected_bib
            if is_all_review_selector(current_bib):
                scope_label = "all"
                matches = load_all_evidence_matches(session_dir)
                summary_lines = all_match_summary_lines(session_dir, matches) if matches else []
            else:
                normalized_bib = normalize_detection_text(current_bib)
                if not normalized_bib:
                    print(f"not a detection-like lookup value: {current_bib}", file=sys.stderr)
                    print()
                    continue
                scope_label = normalized_bib
                matches = load_evidence_matches_for_label(session_dir, normalized_bib)
                summary_lines = (
                    label_match_summary_lines(session_dir, normalized_bib, matches)
                    if matches
                    else []
                )
            if not matches:
                if scope_label == "all":
                    print(f"no evidence events found in {session_dir}", file=sys.stderr)
                else:
                    print(f"no evidence events found for {scope_label} in {session_dir}", file=sys.stderr)
                print()
                continue
            for line in summary_lines:
                print(line)
            print()
            if scope_label == "all":
                status = run_review_bib_action(
                    args=args,
                    session_dir=session_dir,
                    normalized_bib=scope_label,
                    matches=matches,
                    mode="frames",
                )
                print()
                if status != 0:
                    return status
                current_bib = None
                skip_bib_prompt = False
                continue
            while True:
                options = [
                    ("frames", "Browse saved full frames"),
                    ("video-last", "Open last sighting in video"),
                    ("summary", "Print recent evidence lines"),
                    ("another", "Look up another label"),
                ]
                if sighting_span_seconds(matches) >= 60.0:
                    options.insert(1, ("video-first", "Open first sighting in video"))
                chosen_mode = prompt_review_action_or_bib(
                    options,
                    default_value="frames",
                )
                if chosen_mode is None:
                    return 0
                print()
                if chosen_mode.startswith("lookup:"):
                    current_bib = chosen_mode[7:]
                    skip_bib_prompt = True
                    break
                if chosen_mode == "another":
                    current_bib = None
                    skip_bib_prompt = False
                    break
                status = run_review_bib_action(
                    args=args,
                    session_dir=session_dir,
                    normalized_bib=scope_label,
                    matches=matches,
                    mode=chosen_mode,
                )
                print()
                if status != 0:
                    return status
        return 0
    if mode == "interactive":
        mode = "video-last"

    if not args.bib:
        print("review requires a label unless interactive prompts are enabled", file=sys.stderr)
        return 1

    if is_all_review_selector(args.bib):
        normalized_bib = "all"
        matches = load_all_evidence_matches(session_dir)
        summary_lines = all_match_summary_lines(session_dir, matches) if matches else []
    else:
        normalized_bib = normalize_detection_text(args.bib)
        if not normalized_bib:
            print(f"not a detection-like lookup value: {args.bib}", file=sys.stderr)
            return 1
        matches = load_evidence_matches_for_label(session_dir, normalized_bib)
        summary_lines = (
            label_match_summary_lines(session_dir, normalized_bib, matches) if matches else []
        )
    if not matches:
        if normalized_bib == "all":
            print(f"no evidence events found in {session_dir}", file=sys.stderr)
        else:
            print(f"no evidence events found for {normalized_bib} in {session_dir}", file=sys.stderr)
        return 1

    for line in summary_lines:
        print(line)
    print()

    return run_review_bib_action(
        args=args,
        session_dir=session_dir,
        normalized_bib=normalized_bib,
        matches=matches,
        mode=mode,
    )


def resolve_evidence_session_from_args(args: argparse.Namespace, purpose: str) -> Path | None:
    config_path = args.config_file.expanduser()
    config = load_config(config_path)
    if not getattr(args, "target", None) and interactive_mode_enabled(args):
        selected_target = select_session_target(
            args,
            config,
            title=f"Choose a session for {purpose}",
        )
        if not selected_target:
            print(f"no sessions found for {purpose}", file=sys.stderr)
            return None
        args.target = Path(selected_target)

    try:
        session_dir = resolve_session_dir(
            args.recordings_dir.expanduser(),
            str(args.target) if getattr(args, "target", None) else None,
        )
    except FileNotFoundError as exc:
        print(exc, file=sys.stderr)
        return None

    config["last_session_dir"] = str(session_dir)
    save_config(config_path, config)
    return session_dir


def command_record(args: argparse.Namespace) -> int:
    return run_record_command(args, launch_player=False)


def command_go(args: argparse.Namespace) -> int:
