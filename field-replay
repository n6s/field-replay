def source_type_value(args: argparse.Namespace | dict) -> str:
    if isinstance(args, dict):
        return str(args.get("source_type", DEFAULT_SOURCE_TYPE))
    return str(getattr(args, "source_type", DEFAULT_SOURCE_TYPE))


def is_rtsp_source(args: argparse.Namespace | dict) -> bool:
    return source_type_value(args) == "rtsp"


def source_reference(args: argparse.Namespace | dict) -> str:
    if isinstance(args, dict):
        if is_rtsp_source(args):
            return str(args.get("rtsp_url", "")).strip()
        return str(args.get("device", "")).strip()
    if is_rtsp_source(args):
        return str(getattr(args, "rtsp_url", "")).strip()
    return str(getattr(args, "device", "")).strip()


def source_display_label(args: argparse.Namespace | dict) -> str:
    source = source_reference(args) or "unknown"
    if is_rtsp_source(args):
        return f"RTSP {source}"
    return source


def uses_alsa_audio_input(args: argparse.Namespace | dict) -> bool:
    if isinstance(args, dict):
        audio_enabled = bool(args.get("audio", True))
    else:
        audio_enabled = bool(getattr(args, "audio", True))
    return audio_enabled and not is_rtsp_source(args)


def uses_video_passthrough(args: argparse.Namespace | dict) -> bool:
    if isinstance(args, dict):
        mode = args.get("video_codec_mode", DEFAULT_VIDEO_CODEC_MODE)
    else:
        mode = getattr(args, "video_codec_mode", DEFAULT_VIDEO_CODEC_MODE)
    return mode == "copy"


def auto_select_video_codec_mode(args: argparse.Namespace) -> list[str]:
    warnings: list[str] = []
    video_input_format = getattr(args, "video_input_format", DEFAULT_VIDEO_INPUT_FORMAT)
    video_codec_mode = getattr(args, "video_codec_mode", DEFAULT_VIDEO_CODEC_MODE)
    if (
        not is_rtsp_source(args)
        and video_input_format == "h264"
        and video_codec_mode != "copy"
    ):
        args.video_codec_mode = "copy"
        warnings.append(
            "h264 V4L2 input now defaults to passthrough mode; switching video codec mode to copy"
        )
    return warnings


