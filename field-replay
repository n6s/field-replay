def command_watch(args: argparse.Namespace) -> int:
    config_path = args.config_file.expanduser()
    config = load_config(config_path)
    if not args.target and interactive_mode_enabled(args):
        selected_target = select_watch_target(args, config)
        if not selected_target:
            print("no sessions found to watch", file=sys.stderr)
            return 1
        args.target = selected_target

    player = choose_player(args.player)
    if not player:
        requested = args.player or "vlc/mpv/ffplay"
        print(f"player not found: {requested}", file=sys.stderr)
        return 1

    try:
        target_path = resolve_watch_target(args.recordings_dir.expanduser(), args.target)
    except FileNotFoundError as exc:
        print(exc, file=sys.stderr)
        return 1

    if not target_path.exists():
        print(f"watch target not found: {target_path}", file=sys.stderr)
        return 1

    command = build_player_command(player, target_path, args.file_caching_ms)
    print("Player:", shlex.join(command))
    if args.dry_run:
        return 0

    config["last_session_dir"] = str(target_path.parent if target_path.is_file() else target_path)
    save_config(config_path, config)
    return subprocess.call(command)


def command_export(args: argparse.Namespace) -> int:
    timelapse_error = validate_timelapse_args(args)
    if timelapse_error:
        print(timelapse_error, file=sys.stderr)
        return 1

    config_path = args.config_file.expanduser()
    config = load_config(config_path)
    if not args.target and interactive_mode_enabled(args):
        selected_target = select_export_target(args, config)
        if not selected_target:
            print("no sessions found to export", file=sys.stderr)
            return 1
        args.target = selected_target

    try:
        source = resolve_export_source(args.recordings_dir.expanduser(), args.target)
    except FileNotFoundError as exc:
        print(exc, file=sys.stderr)
        return 1

    if not source.source_path.exists():
        print(f"export source not found: {source.source_path}", file=sys.stderr)
        return 1

    ffmpeg_path, supported_encoders = detect_supported_encoders(args.ffmpeg_bin)
    if not ffmpeg_path:
        print(f"ffmpeg binary not found: {args.ffmpeg_bin}", file=sys.stderr)
        return 1

    duration_seconds = probe_media_duration(args.ffmpeg_bin, source.source_path)
    session_metadata = load_session_metadata(source.session_dir)

    if interactive_mode_enabled(args) and args.timelapse_speed is None:
        export_type = choose_export_type(default_type=config.get("last_export_type", "normal"))
        if export_type == "timelapse":
            args.timelapse_speed = choose_timelapse_speed(
                float(config.get("last_timelapse_speed") or DEFAULT_TIMELAPSE_SPEED)
            )
            args.timelapse_output_fps = choose_timelapse_output_fps(
                float(
                    config.get("last_timelapse_output_fps")
                    or DEFAULT_TIMELAPSE_OUTPUT_FPS
                )
            )

    timelapse_error = validate_timelapse_args(args)
    if timelapse_error:
        print(timelapse_error, file=sys.stderr)
        return 1

    timelapse_spec = resolve_timelapse_spec(args, session_metadata, source.source_path)

    if interactive_mode_enabled(args) and not args.preset:
        args.preset = choose_export_preset(
            (
                duration_seconds / timelapse_spec.speed
                if duration_seconds is not None and timelapse_spec
                else duration_seconds
            ),
            default_preset=config.get("last_export_preset"),
            timelapse_spec=timelapse_spec,
        )

    preset_name = args.preset or "share-medium"
    if preset_name not in EXPORT_PRESETS:
        print(f"unknown export preset: {preset_name}", file=sys.stderr)
        return 1

    output_path = export_output_path(
        source.session_dir, preset_name, args.output, session_metadata, timelapse_spec
    )
    preset = EXPORT_PRESETS[preset_name]
    output_duration_seconds = (
        duration_seconds / timelapse_spec.speed
        if duration_seconds is not None and timelapse_spec
        else duration_seconds
    )
    total_mbps = preset_total_mbps(preset_name, timelapse_spec)
    export_encoder, export_preset, export_encoder_reason = resolve_export_encoder(
        ffmpeg_path, supported_encoders, session_metadata
    )
    if not export_encoder:
        print("no supported export video encoder found for this ffmpeg build", file=sys.stderr)
        return 1
    estimated_size = estimate_size_bytes(output_duration_seconds, total_mbps)
    export_command = build_export_command(
        ffmpeg_path,
        source.source_path,
        output_path,
        preset_name,
        export_encoder,
        export_preset,
        timelapse_spec,
    )

    print("Export summary")
    print(f"  Source:      {source.source_path}")
    print(f"  Type:        {timelapse_label(timelapse_spec)}")
    if timelapse_spec:
        print(
            "  Sampling:    "
            f"every {timelapse_spec.frame_skip} frames from "
            f"{timelapse_spec.input_fps:g} fps source"
        )
    print(f"  Preset:      {preset['label']}")
    print(f"  Encoder:     {export_encoder} ({export_encoder_reason})")
    print(f"  Output:      {output_path}")
    if timelapse_spec:
        print(
            "  Duration:    "
            f"{format_duration(duration_seconds)} source -> "
            f"about {format_duration(output_duration_seconds)} output"
        )
    else:
        print(f"  Duration:    {format_duration(duration_seconds)}")
    print(
        "  Est. size:   "
        f"{format_bytes(estimated_size) if estimated_size is not None else 'unknown'}"
    )

    if interactive_mode_enabled(args):
        print()
        if not prompt_yes_no("Start export now?", default=True):
            return 0

    print("Export:", shlex.join(export_command))
    if args.dry_run:
        return 0

    ensure_directory(output_path.parent)
    result = subprocess.run(export_command, check=False)
    if result.returncode != 0:
        return result.returncode
    if not output_path.exists():
        print(f"export did not create output: {output_path}", file=sys.stderr)
        return 1

    config["last_session_dir"] = str(source.session_dir)
    config["last_export_preset"] = preset_name
    config["last_export_type"] = "timelapse" if timelapse_spec else "normal"
    if timelapse_spec:
        config["last_timelapse_speed"] = timelapse_spec.speed
        config["last_timelapse_output_fps"] = timelapse_spec.output_fps
    save_config(config_path, config)
    export_metadata = {
        "created_at": datetime.now().astimezone().isoformat(),
        "source_path": str(source.source_path),
        "source_label": source.source_label,
        "export_type": "timelapse" if timelapse_spec else "normal",
        "preset": preset_name,
        "encoder": export_encoder,
        "encoder_preset": export_preset,
        "encoder_reason": export_encoder_reason,
        "duration_seconds": duration_seconds,
        "output_duration_seconds": output_duration_seconds,
        "estimated_size_bytes": estimated_size,
        "output_path": str(output_path),
        "output_size_bytes": output_path.stat().st_size,
        "ffmpeg_command": export_command,
    }
    if timelapse_spec:
        export_metadata.update(
            {
                "timelapse_speed": timelapse_spec.speed,
                "timelapse_input_fps": timelapse_spec.input_fps,
                "timelapse_output_fps": timelapse_spec.output_fps,
                "timelapse_frame_skip": timelapse_spec.frame_skip,
            }
        )
    try:
        export_metadata_path(output_path).write_text(
            json.dumps(export_metadata, indent=2) + "\n"
        )
    except OSError as exc:
        print(f"warning: could not write export metadata: {exc}", file=sys.stderr)
    print("Export complete")
    print(f"  File:  {output_path}")
    print(f"  Size:  {format_bytes(output_path.stat().st_size)}")
    return 0


def check_ffmpeg_support(ffmpeg_bin: str) -> tuple[str | None, bool]:
    ffmpeg_path, supported_encoders = detect_supported_encoders(ffmpeg_bin)
    return ffmpeg_path, bool(
        ffmpeg_path
        and "h264_nvenc" in supported_encoders
        and encoder_smoke_test(ffmpeg_path, "h264_nvenc")
    )


def validate_source_args(args: argparse.Namespace) -> str | None:
    if is_rtsp_source(args) and not args.rtsp_url.strip():
        return "RTSP source type requires --rtsp-url"
    return None


def source_readiness(args: argparse.Namespace) -> tuple[bool, str]:
    if is_rtsp_source(args):
        source = args.rtsp_url.strip()
        return bool(source), f"{source or '(missing)'} ({'configured' if source else 'missing'})"
    device_exists = Path(args.device).exists()
    return device_exists, f"{args.device} ({'ok' if device_exists else 'missing'})"


def command_doctor(args: argparse.Namespace) -> int:
    for warning in auto_select_video_codec_mode(args):
        print(f"warning: {warning}", file=sys.stderr)

    ffmpeg_path, supported_encoders = detect_supported_encoders(args.ffmpeg_bin)
    has_nvenc = bool(
        ffmpeg_path
        and "h264_nvenc" in supported_encoders
        and encoder_smoke_test(ffmpeg_path, "h264_nvenc")
    )
    resolved_encoder = (
        "copy (passthrough)"
        if uses_video_passthrough(args)
        else resolve_encoder(ffmpeg_path, supported_encoders, args.encoder)
    )
    player = choose_player(args.player)
    source_ok, source_status = source_readiness(args)
    if uses_alsa_audio_input(args):
        audio_ok = alsa_device_exists(args.audio_device)
        audio_status = f"{args.audio_device} ({'ok' if audio_ok else 'missing'})"
    else:
        audio_ok = True
        audio_status = "embedded stream audio (connectivity not checked)" if args.audio else "disabled"

    print(f"ffmpeg:   {ffmpeg_path or 'missing'}")
    print(f"nvenc:    {'yes' if has_nvenc else 'no'}")
    print(f"video:    {args.video_codec_mode}")
    print(f"encoder:  {resolved_encoder or 'missing'}")
    print(f"player:   {player or 'missing'}")
    print(f"type:     {args.source_type}")
    print(f"source:   {source_status}")
    if is_rtsp_source(args):
        print(f"rtsp:     transport={args.rtsp_transport}")
    print(f"audio:    {audio_status}")
    print(f"outputs:  {args.recordings_dir.expanduser()}")

    if not ffmpeg_path or not resolved_encoder or not source_ok or not audio_ok:
        return 1
    return 0


def command_install_mpv_shortcuts(args: argparse.Namespace) -> int:
    target_root = args.mpv_config_dir.expanduser()
    planned_copies: list[tuple[Path, Path]] = []
    missing_sources: list[Path] = []

    for source, relative_target in bundled_mpv_files():
        if not source.exists():
            missing_sources.append(source)
            continue
        planned_copies.append((source, target_root / relative_target))

    if missing_sources:
        print("missing bundled mpv files:", file=sys.stderr)
        for path in missing_sources:
            print(f"  {path}", file=sys.stderr)
        return 1

    print("Installing bundled mpv shortcuts")
    print(f"  Target: {target_root}")
    for source, destination in planned_copies:
        print(f"  Copy:   {source} -> {destination}")

    if args.dry_run:
        return 0

    for source, destination in planned_copies:
        ensure_directory(destination.parent)
        shutil.copy2(source, destination)

    print("mpv shortcuts installed")
    print("  Shortcut: End -> live minus 2 seconds")
    return 0


