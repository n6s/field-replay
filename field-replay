def lock_name(prefix: str, device_name: str) -> str:
    return f"{prefix}-{slugify(device_name)}.lock"


def acquire_device_locks(recordings_dir: Path, args: argparse.Namespace, session_name: str) -> list[Path]:
    lock_dir = recordings_dir / ".locks"
    ensure_directory(lock_dir)
    lock_specs = [(lock_name("video", args.device), args.device)]
    if args.audio:
        lock_specs.append((lock_name("audio", args.audio_device), args.audio_device))

    acquired: list[Path] = []
    try:
        for filename, device_name in lock_specs:
            lock_path = lock_dir / filename
            fd = os.open(lock_path, os.O_CREAT | os.O_EXCL | os.O_WRONLY, 0o644)
            with os.fdopen(fd, "w") as handle:
                handle.write(f"pid={os.getpid()}\n")
                handle.write(f"session={session_name}\n")
                handle.write(f"device={device_name}\n")
            acquired.append(lock_path)
    except FileExistsError:
        release_device_locks(acquired)
        raise RuntimeError(f"device already in use: {device_name}")
    return acquired


def release_device_locks(lock_paths: Sequence[Path]) -> None:
    for lock_path in lock_paths:
        try:
            lock_path.unlink()
        except FileNotFoundError:
            continue


def wait_for_capture_output(paths: SessionPaths, process: subprocess.Popen[bytes], timeout_seconds: float = 5.0) -> bool:
    deadline = time.time() + timeout_seconds
    while time.time() < deadline:
        if has_timeshift_session(paths):
            return True
        if process.poll() is not None:
            return False
        time.sleep(0.2)
    return has_timeshift_session(paths)


def update_latest_symlink(paths: SessionPaths) -> None:
    try:
        if paths.latest_link.is_symlink() or paths.latest_link.exists():
            paths.latest_link.unlink()
        paths.latest_link.symlink_to(paths.session_dir.name)
    except OSError as exc:
        print(f"warning: could not update latest symlink: {exc}", file=sys.stderr)


def has_timeshift_session(paths: SessionPaths) -> bool:
    return paths.timeshift_path.exists() and paths.timeshift_path.stat().st_size > 0


def build_timeshift_archive_command(
    paths: SessionPaths, ffmpeg_bin: str, archive_format: str
) -> list[str]:
    command = [
        ffmpeg_bin,
        "-hide_banner",
        "-y",
        "-i",
        paths.timeshift_path.name,
        "-c",
        "copy",
    ]
    if archive_format == "mp4":
        command.extend(["-movflags", "+faststart"])
    command.append(paths.archive_path.name)
    return command


def create_archive(paths: SessionPaths, args: argparse.Namespace) -> tuple[bool, str]:
    if not has_timeshift_session(paths):
        return False, "no recording data was captured"

    archive_command = build_timeshift_archive_command(
        paths, args.ffmpeg_bin, args.archive_format
    )
    source_label = paths.timeshift_path.name

    print("Archive:", shlex.join(archive_command))
    result = subprocess.run(archive_command, cwd=paths.session_dir, check=False)
    if result.returncode != 0:
        return False, f"archive remux failed with exit code {result.returncode}"
    if not paths.archive_path.exists() or paths.archive_path.stat().st_size == 0:
        return False, "archive file was created but is empty"
    return True, f"archived from {source_label}"


