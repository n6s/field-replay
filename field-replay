            compare_frames=False,
            output_root=variant_output_root,
            sample_points=sample_points,
            annotate_frames=annotate_frames,
            frame_filter=variant.frame_filter,
            dry_run=False,
        )
        summary = summarize_vision_scan_output(variant_output_root)
        result = {
            "label": variant.label,
            "variant_spec": variant.spec,
            "output_dir": str(variant_output_root),
            "frame_filter": variant.frame_filter,
            "summary": summary,
        }
        if reference_summary is None:
            reference_summary = summary
        else:
            result["compare_to_reference"] = compare_vision_summaries(reference_summary, summary)
        results.append(result)

    summary_json_path, summary_text_path = write_vision_sweep_summary(
        output_root,
        source.source_path,
        sample_points,
        results,
    )
    print()
    print("Vision sweep complete")
    print(f"  JSON: {summary_json_path}")
    print(f"  Text: {summary_text_path}")
    for result in results:
        summary = result["summary"]
        compare = result.get("compare_to_reference") or {}
        compare_bits = []
        if compare.get("unique_recall") is not None:
            compare_bits.append(f"unique recall {compare['unique_recall']:.0%}")
        if compare.get("instance_recall") is not None:
            compare_bits.append(f"sample recall {compare['instance_recall']:.0%}")
        comparison_suffix = f", {', '.join(compare_bits)}" if compare_bits else ""
        print(
            "  "
            f"{result['label']}: unique {summary['unique_detection_count']}, "
            f"promoted {summary['promoted_total']}, "
            f"median {summary['median_elapsed_ms'] or 0} ms"
            f"{comparison_suffix}"
        )
    return 0


