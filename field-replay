def video_size_label(video_size: str | None) -> str:
    if not video_size or "x" not in video_size:
        return "video"
    try:
        width_text, height_text = video_size.lower().split("x", 1)
        width = int(width_text)
        height = int(height_text)
    except ValueError:
        return video_size.replace("x", "x")
    if width == 1280 and 700 <= height <= 740:
        return "720p"
    if width == 1920 and 1040 <= height <= 1100:
        return "1080p"
    if width == 3840 and 2100 <= height <= 2200:
        return "2160p"
    return f"{width}x{height}"


def parse_scale_dimensions(value: str) -> tuple[int, int] | None:
    normalized = value.strip().lower()
    normalized = VISION_RESOLUTION_ALIASES.get(normalized, normalized)
    if "x" not in normalized:
        return None
    try:
        width_text, height_text = normalized.split("x", 1)
        width = int(width_text)
        height = int(height_text)
    except ValueError:
        return None
    if width <= 0 or height <= 0:
        return None
    return width, height


def scale_filter_for_dimensions(width: int, height: int) -> str:
    return (
        "scale="
        f"w={width}:h={height}:force_original_aspect_ratio=decrease,"
        f"pad={width}:{height}:(ow-iw)/2:(oh-ih)/2:black"
    )


def frame_filter_for_vision_size(vision_size: str | None) -> str | None:
    if not vision_size:
        return None
    dimensions = parse_scale_dimensions(vision_size.strip())
    if not dimensions:
        raise ValueError(
            f"invalid vision size: {vision_size!r}; expected WxH like 640x360"
        )
    width, height = dimensions
    return f"scale={width}:{height}:force_original_aspect_ratio=decrease"


def resolve_vision_variant(spec: str) -> VisionSweepVariant:
    normalized = spec.strip().lower()
    if normalized in ("", "source", "native", "full", "fullres", "full-resolution"):
        return VisionSweepVariant(
            spec=spec,
            label="source",
            output_slug="source",
            frame_filter=None,
        )
    dimensions = parse_scale_dimensions(normalized)
    if not dimensions:
        raise ValueError(
            f"invalid resolution variant: {spec!r}; expected 'source' or WxH like 640x360"
        )
    width, height = dimensions
    resolution_label = video_size_label(f"{width}x{height}")
    return VisionSweepVariant(
        spec=spec,
        label=resolution_label,
        output_slug=f"{width}x{height}",
        frame_filter=scale_filter_for_dimensions(width, height),
    )


def resolve_vision_variants(variant_specs: Sequence[str] | None) -> list[VisionSweepVariant]:
    requested_specs = list(variant_specs or DEFAULT_VISION_SWEEP_VARIANTS)
    variants: list[VisionSweepVariant] = []
    seen_slugs: set[str] = set()
    for spec in requested_specs:
        variant = resolve_vision_variant(spec)
        if variant.output_slug in seen_slugs:
            continue
        variants.append(variant)
        seen_slugs.add(variant.output_slug)
    return variants


