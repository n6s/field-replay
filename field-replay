            print("Profile name cannot be blank.")
            continue
        return profile_name


def command_setup(args: argparse.Namespace) -> int:
    config_path = args.config_file.expanduser()
    config = load_config(config_path)
    profiles = config.get("profiles", {})

    selected_profile_name = args.profile
    if interactive_mode_enabled(args):
        selected_profile_name = choose_saved_profile(
            config,
            default_manual=not bool(args.profile),
            preferred_profile=args.profile,
        )

    if selected_profile_name and selected_profile_name in profiles:
        apply_profile(args, profiles[selected_profile_name])
    elif not interactive_mode_enabled(args) and not args.dry_run and not selected_profile_name:
        print(
            "setup --no-interactive requires --profile for the saved profile name",
            file=sys.stderr,
        )
        return 1

    if interactive_mode_enabled(args):
        print()
        args.device = select_video_device(args.device)
        print()
        args.audio, args.audio_device = select_audio_source(args.audio, args.audio_device)
        print()
        args.recordings_dir = select_storage_path(args.recordings_dir.expanduser())
        print()

    ffmpeg_path, supported_encoders = detect_supported_encoders(args.ffmpeg_bin)
    resolved_encoder = resolve_encoder(ffmpeg_path, supported_encoders, args.encoder)
    if resolved_encoder:
        args.encoder = resolved_encoder

    if args.probe:
        if not ffmpeg_path:
            print(f"ffmpeg binary not found: {args.ffmpeg_bin}", file=sys.stderr)
            return 1

        print(f"Probing video modes for {args.device}...")
        selected_size, selected_fps, selected_format, video_results, video_failure = choose_video_profile_settings(
            ffmpeg_path,
            args.device,
            args.video_size,
            args.framerate,
            args.video_input_format,
        )
        if video_results:
            print_video_probe_results(video_results)
            args.video_size = selected_size
            args.framerate = selected_fps
            args.video_input_format = selected_format
        else:
            print("Video probe did not find a better mode. Keeping current defaults.")
            if video_failure:
                print(f"  Probe detail: {video_failure}")

        if args.audio:
            print()
            print(f"Probing audio input modes for {args.audio_device}...")
            input_rate, input_channels, audio_results, audio_failure = choose_audio_profile_settings(
                ffmpeg_path, args.audio_device, args.audio_input_rate, args.audio_input_channels
            )
            if audio_results:
                print_audio_probe_results(audio_results)
                args.audio_input_rate = input_rate
                args.audio_input_channels = input_channels
            else:
                print("Audio probe did not find a working input mode. Audio will stay as configured.")
                if audio_failure:
                    print(f"  Probe detail: {audio_failure}")

        print()

    print("Setup summary")
    print(f"  Video device:      {args.device}")
    print(
        f"  Video input fmt:   {args.video_input_format if args.video_input_format != DEFAULT_VIDEO_INPUT_FORMAT else 'auto'}"
    )
    print(f"  Video mode:        {args.video_size} @ {args.framerate} fps")
    print(f"  Audio device:      {args.audio_device if args.audio else 'disabled'}")
    if args.audio:
        print(
            f"  Audio input mode:  {args.audio_input_rate} Hz, {args.audio_input_channels} channel(s)"
        )
    print(f"  Storage:           {storage_summary(args.recordings_dir)}")
    print(f"  Video encoder:     {args.encoder}")
    print(
        "  Video timestamp:   "
        f"{'wall-clock overlay' if args.video_timestamp else 'disabled'}"
    )

    if args.dry_run:
        return 0

    if interactive_mode_enabled(args):
        print()
        if not prompt_yes_no("Save this setup?", default=True):
            return 0

    profile_name = ensure_profile_name(config, existing_name=selected_profile_name)
    profiles[profile_name] = profile_from_args(args)
    config["profiles"] = profiles
    config["last_profile"] = profile_name
    config["last_recordings_dir"] = str(args.recordings_dir.expanduser())
    save_config(config_path, config)
    print(f"Saved profile: {profile_name}")
    return 0


def list_session_dirs(recordings_root: Path) -> list[Path]:
    if not recordings_root.exists():
        return []
    sessions: list[Path] = []
    for child in sorted(recordings_root.iterdir()):
        if child.name == "latest":
            continue
        if not child.is_dir() or child.name.startswith("."):
            continue
        if (child / "session.json").exists() or (child / DEFAULT_TIMESHIFT_NAME).exists():
            sessions.append(child)
    return sessions


def recent_sessions(args: argparse.Namespace, config: dict) -> list[Path]:
    sessions: list[Path] = []
    for root in known_recordings_roots(args, config):
        sessions.extend(list_session_dirs(root))

    unique_sessions: list[Path] = []
    seen: set[str] = set()
    for session in sorted(sessions, key=lambda path: path.stat().st_mtime, reverse=True):
        try:
            canonical = str(session.resolve())
        except OSError:
            canonical = str(session)
        if canonical in seen:
            continue
        seen.add(canonical)
        unique_sessions.append(session)
    return unique_sessions


def session_target_summary(session_dir: Path) -> str:
