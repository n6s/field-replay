    for offset_seconds in sample_points:
        try:
            extract_frame_at_time(
                ffmpeg_path,
                source.source_path,
                offset_seconds,
                runtime_paths["scratch_frame"],
            )
            process_vision_frame(
                runtime_paths=runtime_paths,
                session_dir=source.session_dir,
                frame_path=runtime_paths["scratch_frame"],
                ffmpeg_bin=ffmpeg_path,
