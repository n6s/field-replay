def choose_saved_profile(
    config: dict, default_manual: bool = False, preferred_profile: str | None = None
) -> str | None:
    profiles = config.get("profiles", {})
    if not profiles:
        return None
    options = []
    for name, profile in sorted(profiles.items()):
        details = [profile.get("device", "unknown device")]
        if profile.get("video_size") and profile.get("framerate"):
            details.append(f"{profile['video_size']} @ {profile['framerate']} fps")
        recordings_dir = profile.get("recordings_dir")
        if recordings_dir:
            details.append(str(Path(recordings_dir).expanduser()))
        options.append((name, f"{name} ({'; '.join(details)})"))
    if default_manual:
        options.append(("__manual__", "Manual / one-time setup"))
        default_value = "__manual__"
    else:
        default_value = preferred_profile or config.get("last_profile")
        if default_value not in profiles:
            default_value = options[0][0]
        options.append(("__manual__", "Manual / one-time setup"))
    choice = prompt_menu("Choose a setup", options, default_value=default_value)
    if choice == "__manual__":
        return None
    return choice


def candidate_storage_paths(current: Path) -> list[Path]:
    user = os.environ.get("USER", "")
    candidates = [current.expanduser()]
    extras = [
        Path("/mnt/storage") / "field-replay",
        Path("/mnt/storage"),
        Path(f"/media/{user}") if user else None,
        Path(f"/run/media/{user}") if user else None,
    ]
    for extra in extras:
        if extra is None or not extra.exists():
            continue
        if extra.is_dir() and extra.name == "field-replay":
            candidates.append(extra)
            continue
        if extra.is_dir() and extra.parent.name in {"media", "run"}:
            for child in sorted(extra.iterdir()):
                if child.is_dir():
                    candidates.append(child / "field-replay")
        elif extra.is_dir():
            candidates.append(extra / "field-replay")

    unique: list[Path] = []
    seen: set[str] = set()
    for candidate in candidates:
        key = str(candidate)
        if key not in seen:
            seen.add(key)
            unique.append(candidate)
    return unique


def select_video_device(current_device: str) -> str:
    devices = list_video_devices()
    options = [(device.path, device.label) for device in devices]
    default_device = v4l_persistent_alias(current_device) or current_device
    if not options:
        custom = prompt_text("No video devices discovered. Enter a video device path", current_device)
        return custom

    option_values = {value for value, _ in options}
    if current_device not in option_values and default_device not in option_values:
        options.append((current_device, f"{current_device} (current/custom)"))
    options.append(("__custom__", "Enter a custom video device path"))
    choice = prompt_menu("Video source", options, default_value=default_device)
    if choice == "__custom__":
        return prompt_text("Video device path", current_device)
    return choice


