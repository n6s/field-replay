def calibrate_motion_window(
    *,
    ffmpeg_bin: str,
    source_path: Path,
    duration_seconds: float,
    sample_interval: float,
    motion_size: str,
    motion_zone: str | None,
) -> list[dict]:
    total_duration = ffprobe_duration_seconds(source_path) or 0.0
    if total_duration <= 0:
        return []
    window_duration = max(duration_seconds, sample_interval)
    start_seconds = max(total_duration - window_duration, 0.0)
    previous_frame: bytes | None = None
    samples: list[dict] = []
    current = start_seconds
    while current <= total_duration + 0.001:
        try:
            frame = extract_motion_plane_at_time(
                ffmpeg_bin,
                source_path,
                current,
                motion_size=motion_size,
                motion_zone=motion_zone,
                motion_zone_grid=DEFAULT_MOTION_ZONE_GRID,
            )
        except RuntimeError:
            current += max(sample_interval, 0.1)
            continue
        mean_diff, changed_pct = compute_motion_metrics(previous_frame, frame)
        previous_frame = frame
        if mean_diff is not None and changed_pct is not None:
            samples.append(
                {
                    "t": round(current, 1),
                    "mean_diff": mean_diff,
                    "changed_pct": changed_pct,
                }
            )
        current += max(sample_interval, 0.1)
    return samples


def summarize_motion_calibration(samples: Sequence[dict]) -> dict:
    mean_values = [
        float(sample["mean_diff"])
        for sample in samples
        if sample.get("mean_diff") is not None
    ]
    changed_values = [
        float(sample["changed_pct"])
        for sample in samples
        if sample.get("changed_pct") is not None
    ]
    return {
        "samples": len(samples),
        "mean_median": statistics.median(mean_values) if mean_values else None,
        "mean_p95": percentile_value(mean_values, 0.95),
        "mean_p99": percentile_value(mean_values, 0.99),
        "changed_median": (
            statistics.median(changed_values) if changed_values else None
        ),
        "changed_p95": percentile_value(changed_values, 0.95),
        "changed_p99": percentile_value(changed_values, 0.99),
    }


def motion_calibration_summary_lines(summary: dict) -> list[str]:
    if not summary.get("samples"):
        return ["Calibration: no usable motion samples"]
    return [
        "Calibration baseline:",
        f"  Samples:          {summary['samples']}",
        f"  Mean median:      {summary['mean_median']:.2f}",
        f"  Mean p95:         {summary['mean_p95']:.2f}",
        f"  Changed median:   {summary['changed_median']:.2f}%",
        f"  Changed p95:      {summary['changed_p95']:.2f}%",
    ]


def motion_candidate_score(
    mean_diff: float | None,
    changed_pct: float | None,
    *,
    current_threshold: float,
    min_changed_pct: float,
) -> float:
    mean_part = (
        float(mean_diff) / max(current_threshold, 0.1)
        if mean_diff is not None
        else 0.0
    )
    change_part = (
        float(changed_pct) / max(min_changed_pct, 0.1)
        if changed_pct is not None
        else 0.0
    )
    return mean_part + change_part


def build_motion_candidate(
    records: Sequence[dict],
    *,
    kind: str,
    current_threshold: float,
    min_changed_pct: float,
) -> dict:
    peak_record = max(
        records,
        key=lambda record: motion_candidate_score(
            (record.get("motion_gate") or {}).get("mean_diff"),
            (record.get("motion_gate") or {}).get("changed_pct"),
            current_threshold=current_threshold,
            min_changed_pct=min_changed_pct,
        ),
    )
    motion_gate = peak_record.get("motion_gate") or {}
    first_record = records[0]
    last_record = records[-1]
    return {
        "kind": kind,
        "t": float(peak_record.get("t") or 0.0),
        "t_start": float(first_record.get("t") or 0.0),
        "t_end": float(last_record.get("t") or 0.0),
        "w": peak_record.get("w"),
        "zone": motion_gate.get("zone"),
        "mean_diff": motion_gate.get("mean_diff"),
        "changed_pct": motion_gate.get("changed_pct"),
        "reason": motion_gate.get("reason"),
        "sample_count": len(records),
        "score": motion_candidate_score(
            motion_gate.get("mean_diff"),
            motion_gate.get("changed_pct"),
            current_threshold=current_threshold,
            min_changed_pct=min_changed_pct,
        ),
    }


def group_motion_records_into_candidates(
    records: Sequence[dict],
    *,
    kind: str,
    current_threshold: float,
    min_changed_pct: float,
    group_gap_seconds: float = 4.0,
) -> list[dict]:
    sorted_records = sorted(records, key=event_sort_key)
    if not sorted_records:
        return []
    groups: list[list[dict]] = []
    current_group: list[dict] = [sorted_records[0]]
    for record in sorted_records[1:]:
        previous_time = float(current_group[-1].get("t") or 0.0)
        current_time = float(record.get("t") or 0.0)
        if (current_time - previous_time) <= group_gap_seconds:
            current_group.append(record)
        else:
            groups.append(current_group)
            current_group = [record]
    groups.append(current_group)
    return [
        build_motion_candidate(
            group,
            kind=kind,
            current_threshold=current_threshold,
            min_changed_pct=min_changed_pct,
        )
        for group in groups
    ]


def load_motion_candidates(
    session_dir: Path,
    *,
    current_threshold: float,
    min_changed_pct: float,
    limit: int,
) -> dict[str, list[dict]]:
    runtime_paths = vision_output_paths(session_dir / "vision-live")
    debug_records = load_jsonl_records(runtime_paths["debug_log"])
    triggered_records: list[dict] = []
    near_miss_records: list[dict] = []
    for record in debug_records:
        motion_gate = record.get("motion_gate")
        if not isinstance(motion_gate, dict):
            continue
        if motion_gate.get("triggered"):
            triggered_records.append(record)
            continue
        mean_diff = motion_gate.get("mean_diff")
        changed_pct = motion_gate.get("changed_pct")
        if mean_diff is None or changed_pct is None:
            continue
        if (
            changed_pct >= min_changed_pct
            or mean_diff >= max(current_threshold * 0.5, 1.0)
        ):
            near_miss_records.append(record)
    triggered_candidates = group_motion_records_into_candidates(
        triggered_records,
        kind="triggered",
        current_threshold=current_threshold,
        min_changed_pct=min_changed_pct,
    )
    triggered_candidates.sort(key=event_sort_key)
    near_miss_candidates = group_motion_records_into_candidates(
        near_miss_records,
        kind="near-miss",
        current_threshold=current_threshold,
        min_changed_pct=min_changed_pct,
    )
    near_miss_candidates.sort(key=lambda item: item.get("score", 0.0), reverse=True)
    return {
        "triggered": triggered_candidates[:limit],
        "near_miss": near_miss_candidates[:limit],
    }


def motion_candidate_summary_line(candidate: dict) -> str:
