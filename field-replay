def apply_runtime_motion_zone_update(
    runtime_paths: dict[str, Path],
    *,
    current_zone: str | None,
) -> tuple[bool, str | None]:
    payload = load_json_file(runtime_paths["runtime_control"])
    if "motion_zone" not in payload:
        return False, current_zone
    raw_zone = payload.get("motion_zone")
    if raw_zone is not None and not isinstance(raw_zone, str):
        print(
            f"warning: ignoring invalid runtime motion zone payload in {runtime_paths['runtime_control']}",
            file=sys.stderr,
        )
        return False, current_zone
    normalized_zone, error = parse_motion_zone_value(raw_zone)
    if error:
        print(f"warning: ignoring runtime motion zone update: {error}", file=sys.stderr)
        return False, current_zone
    if normalized_zone == current_zone:
        return False, current_zone
    return True, normalized_zone


def extract_frame_at_time(
    ffmpeg_bin: str,
    source_path: Path,
    offset_seconds: float,
    output_path: Path,
    *,
    frame_filter: str | None = None,
) -> None:
    ensure_directory(output_path.parent)
    command = [
        ffmpeg_bin,
        "-hide_banner",
        "-loglevel",
        "error",
        "-y",
        "-ss",
        f"{max(0.0, offset_seconds):.3f}",
        "-i",
        str(source_path),
    ]
    if frame_filter:
        command.extend(["-vf", frame_filter])
    command.extend(
        [
            "-frames:v",
            "1",
            "-q:v",
            "2",
            str(output_path),
        ]
    )
    result = subprocess.run(
        command,
        capture_output=True,
        text=True,
        check=False,
    )
    if result.returncode != 0:
        raise RuntimeError(result.stderr.strip() or "ffmpeg timed frame extraction failed")
    if not output_path.exists() or output_path.stat().st_size == 0:
        raise RuntimeError("ffmpeg did not produce a frame at the requested offset")


def extract_motion_plane_at_time(
    ffmpeg_bin: str,
    source_path: Path,
    offset_seconds: float,
    *,
    motion_size: str,
    motion_zone: str | None = None,
    motion_zone_grid: int = DEFAULT_MOTION_ZONE_GRID,
) -> bytes:
    dimensions = parse_scale_dimensions(motion_size)
    if not dimensions:
        raise ValueError(
            f"invalid motion size: {motion_size!r}; expected WxH like 160x90"
        )
    width, height = dimensions
    motion_filter_parts = [
        f"scale={width}:{height}:force_original_aspect_ratio=decrease,"
        f"pad={width}:{height}:(ow-iw)/2:(oh-ih)/2:black,"
        "format=gray"
    ]
    crop_x, crop_y, crop_width, crop_height = motion_zone_pixel_rect(
        motion_zone,
        width=width,
        height=height,
        grid_size=motion_zone_grid,
    )
    if motion_zone:
        motion_filter_parts.append(
            f"crop={crop_width}:{crop_height}:{crop_x}:{crop_y}"
        )
    motion_filter = ",".join(motion_filter_parts)
    command = [
        ffmpeg_bin,
        "-hide_banner",
        "-loglevel",
        "error",
        "-y",
        "-ss",
        f"{max(0.0, offset_seconds):.3f}",
        "-i",
        str(source_path),
        "-vf",
        motion_filter,
        "-frames:v",
        "1",
        "-f",
        "rawvideo",
        "-pix_fmt",
        "gray",
        "-",
    ]
    result = subprocess.run(
        command,
        capture_output=True,
        check=False,
    )
    if result.returncode != 0:
        stderr = result.stderr.decode("utf-8", errors="ignore").strip()
        raise RuntimeError(stderr or "ffmpeg motion frame extraction failed")
    expected_size = crop_width * crop_height
    if len(result.stdout) != expected_size:
        raise RuntimeError(
            f"unexpected motion frame size: got {len(result.stdout)} bytes, expected {expected_size}"
        )
    return result.stdout


def compute_motion_metrics(
    previous_frame: bytes | None,
    current_frame: bytes,
    *,
    pixel_delta_threshold: int = DEFAULT_MOTION_PIXEL_DELTA,
) -> tuple[float | None, float | None]:
    if previous_frame is None:
        return None, None
    if len(previous_frame) != len(current_frame):
        raise ValueError("motion frames must have matching sizes")
    if not current_frame:
        return 0.0, 0.0

    total_delta = 0
    changed_pixels = 0
    frame_length = len(current_frame)
    for previous_value, current_value in zip(previous_frame, current_frame):
        delta = abs(current_value - previous_value)
        total_delta += delta
        if delta >= pixel_delta_threshold:
            changed_pixels += 1

    mean_diff = total_delta / frame_length
    changed_pct = (changed_pixels / frame_length) * 100.0
    return mean_diff, changed_pct


def evaluate_motion_gate(
    *,
    enabled: bool,
    previous_frame: bytes | None,
    current_frame: bytes,
    mean_threshold: float,
    min_changed_pct: float,
) -> MotionSampleResult:
    if not enabled:
        return MotionSampleResult(
            enabled=False,
            mean_diff=None,
            changed_pct=None,
            triggered=True,
            gate_open=True,
            reason="disabled",
        )

    mean_diff, changed_pct = compute_motion_metrics(previous_frame, current_frame)
    if mean_diff is None or changed_pct is None:
        return MotionSampleResult(
            enabled=True,
            mean_diff=None,
            changed_pct=None,
            triggered=False,
            gate_open=False,
            reason="warming-up",
        )

    triggered = mean_diff >= mean_threshold and changed_pct >= min_changed_pct
    if triggered:
        reason = "triggered"
    elif mean_diff < mean_threshold and changed_pct < min_changed_pct:
        reason = "below-mean-and-change"
    elif mean_diff < mean_threshold:
        reason = "below-mean"
    else:
        reason = "below-change"

    return MotionSampleResult(
        enabled=True,
        mean_diff=mean_diff,
        changed_pct=changed_pct,
        triggered=triggered,
        gate_open=triggered,
        reason=reason,
    )


def media_sample_points(duration_seconds: float, sample_interval: float) -> list[float]:
    sample_interval = max(sample_interval, 0.1)
    if duration_seconds <= 0:
        return [0.0]
    sample_points: list[float] = []
    current = 0.0
    while current <= duration_seconds + 0.001:
        sample_points.append(round(current, 3))
        current += sample_interval
    return sample_points


def live_sample_offset(
    duration_seconds: float,
    *,
    tail_offset: float,
    sample_interval: float,
) -> float:
    available_offset = max(duration_seconds - max(tail_offset, 0.0), 0.0)
    interval = max(sample_interval, 0.1)
    return int(available_offset / interval) * interval


def event_wall_time(now: datetime) -> str:
    return now.astimezone().isoformat(timespec="seconds")


def vision_event_log_line(payload: dict) -> str:
    label = event_detection_label(payload) or "unknown"
    noun = "bib" if is_bib_detection_label(label) else "detection"
    return (
        f"{payload['w']} {noun} {label} vision "
        f"t={format_duration(payload.get('t'))} frame={payload.get('f', '-')}"
    )


def event_sort_key(event: dict) -> tuple[float, str]:
    try:
        rel_time = float(event.get("t") or 0.0)
    except (TypeError, ValueError):
        rel_time = 0.0
    wall_time = str(event.get("w") or "")
    return rel_time, wall_time


def parse_seek_time_text(value: str) -> float | None:
    stripped = value.strip()
    if not stripped:
        return None
    try:
        seconds = float(stripped)
    except ValueError:
        parts = stripped.split(":")
        if len(parts) not in {2, 3}:
            return None
        try:
            numbers = [int(part) for part in parts]
        except ValueError:
            return None
        if len(numbers) == 2:
            minutes, seconds_value = numbers
            hours = 0
        else:
            hours, minutes, seconds_value = numbers
        if minutes < 0 or seconds_value < 0 or hours < 0:
            return None
        seconds = (hours * 3600) + (minutes * 60) + seconds_value
    return max(seconds, 0.0)


def percentile_value(values: Sequence[float], percentile: float) -> float | None:
    if not values:
        return None
    if len(values) == 1:
        return float(values[0])
    sorted_values = sorted(float(value) for value in values)
    position = max(0.0, min(1.0, percentile)) * (len(sorted_values) - 1)
    lower_index = int(position)
    upper_index = min(lower_index + 1, len(sorted_values) - 1)
    lower_value = sorted_values[lower_index]
    upper_value = sorted_values[upper_index]
    if upper_index == lower_index:
        return lower_value
    fraction = position - lower_index
    return lower_value + ((upper_value - lower_value) * fraction)


def load_motion_tune_context(
