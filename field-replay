def run_review_bib_action(
    *,
    args: argparse.Namespace,
    session_dir: Path,
    normalized_bib: str,
    matches: Sequence[dict],
    mode: str,
) -> int:
    if mode == "summary":
        print("Evidence")
        for match in matches[-args.limit :]:
            print(
                f"  {match.get('w', '?')}  "
                f"t={format_duration(match.get('t'))}  "
                f"conf={event_confidence_label(match)}  "
                f"src={match.get('_source', '?')}  "
                f"frame={match.get('f', '-')}"
            )
        return 0

    if mode in {"video-last", "video-first", "video-best"}:
        chosen_match = (
            matches[-1]
            if mode == "video-last"
            else matches[0]
        )
        player = choose_player(args.player)
        if not player:
            requested = args.player or "vlc/mpv/ffplay"
            print(f"player not found: {requested}", file=sys.stderr)
            return 1
        try:
            target_path = resolve_watch_target(
                args.recordings_dir.expanduser(), str(session_dir)
            )
        except FileNotFoundError as exc:
            print(exc, file=sys.stderr)
            return 1
        start_seconds = max(float(chosen_match.get("t") or 0.0) - args.pre_roll, 0.0)
        command = build_player_command(
            player,
            target_path,
            args.file_caching_ms,
            start_seconds=start_seconds,
        )
        action_label = "last sighting" if mode == "video-last" else "first sighting"
        print(
            f"Opening {action_label} for {normalized_bib} at "
            f"{format_duration(start_seconds)}"
        )
        print("Player:", shlex.join(command))
        if args.dry_run:
            return 0
        return subprocess.call(command)

    if mode == "frames":
        image_paths: list[Path] = []
        seen_paths: set[Path] = set()
        for match in matches:
            image_path = session_asset_path(session_dir, str(match.get("f") or ""))
            if image_path is None or not image_path.exists() or image_path in seen_paths:
                continue
            seen_paths.add(image_path)
            image_paths.append(image_path)
        if not image_paths:
            print(
                f"no saved frames found for {normalized_bib}",
                file=sys.stderr,
            )
            return 0
        viewer = choose_image_viewer(args.image_viewer)
        if not viewer:
            requested = args.image_viewer or "eog"
            print(f"image viewer not found: {requested}", file=sys.stderr)
            return 1
        viewer_image_paths = image_paths
        launch_in_background = False
        if normalized_bib == "all":
            viewer_image_paths = image_paths[:1]
            launch_in_background = True
            print(
                f"Opening the full promoted frame collection from the first frame "
                f"for {normalized_bib}"
            )
        else:
            print(
                f"Opening {len(image_paths)} frame"
                f"{'' if len(image_paths) == 1 else 's'} for {normalized_bib}"
            )
        command = build_image_viewer_command(viewer, viewer_image_paths)
        print("Viewer:", shlex.join(command))
        if args.dry_run:
            return 0
        if launch_in_background:
            launch_background_viewer(command)
            return 0
        return subprocess.call(command)

    print(f"unknown review mode: {mode}", file=sys.stderr)
    return 1


def prompt_review_bib_value(current_bib: str | None = None) -> str | None:
    while True:
        prompt = "Bib number, PACER, or all"
        if current_bib:
            prompt += f" [{current_bib}]"
        prompt += " (q to quit): "
        raw = input(prompt).strip()
        if not raw and current_bib:
            return current_bib
        if raw.lower() in {"q", "quit"}:
            return None
        if raw:
            return raw
        print("Enter a bib number, PACER, all, or q to quit.")


def prompt_review_action_or_bib(
    options: Sequence[tuple[str, str]],
    default_value: str | None = None,
) -> str | None:
    print("Review action")
    default_index = None
    for index, (value, label) in enumerate(options, start=1):
        marker = ""
        if value == default_value:
            default_index = index
            marker = " [default]"
        print(f"  {index}. {label}{marker}")
    print("  q. Quit")

    while True:
        prompt = "Select an option"
        if default_index is not None:
            prompt += f" [{default_index}]"
        prompt += ", or enter another bib: "
        raw = input(prompt).strip()
        if not raw and default_index is not None:
            return options[default_index - 1][0]
        if raw.lower() in {"q", "quit"}:
            return None
        if raw.isdigit():
            selected = int(raw)
            if 1 <= selected <= len(options):
                return options[selected - 1][0]
        if raw:
            return f"bib:{raw}"
        print("Enter a menu number, another bib, all, or q to quit.")


def command_review_bib(args: argparse.Namespace) -> int:
    session_dir = resolve_evidence_session_from_args(args, "bib review")
    if session_dir is None:
        return 1

    if not evidence_event_sources_for_session(session_dir):
        print(f"no evidence event logs found under {session_dir}", file=sys.stderr)
        return 1

    mode = args.mode
    if mode == "interactive" and interactive_mode_enabled(args):
        current_bib = args.bib
        skip_bib_prompt = False
        print(f"Review session: {session_dir}")
        print()
        while True:
            if skip_bib_prompt and current_bib:
                selected_bib = current_bib
                skip_bib_prompt = False
            else:
                selected_bib = prompt_review_bib_value(current_bib)
            if selected_bib is None:
                return 0
            current_bib = selected_bib
            if is_all_review_selector(current_bib):
                scope_label = "all"
                matches = load_all_evidence_matches(session_dir)
                summary_lines = all_match_summary_lines(session_dir, matches) if matches else []
            else:
                normalized_bib = normalize_bib_text(current_bib)
                if not normalized_bib:
                    print(f"not a bib-like lookup value: {current_bib}", file=sys.stderr)
                    print()
                    continue
                scope_label = normalized_bib
                matches = load_evidence_matches_for_bib(session_dir, normalized_bib)
                summary_lines = (
                    bib_match_summary_lines(session_dir, normalized_bib, matches) if matches else []
                )
            if not matches:
                if scope_label == "all":
                    print(f"no evidence events found in {session_dir}", file=sys.stderr)
                else:
                    print(f"no evidence events found for bib {scope_label} in {session_dir}", file=sys.stderr)
                print()
                continue
            for line in summary_lines:
                print(line)
            print()
            if scope_label == "all":
                status = run_review_bib_action(
                    args=args,
                    session_dir=session_dir,
                    normalized_bib=scope_label,
                    matches=matches,
                    mode="frames",
                )
                print()
                if status != 0:
                    return status
                current_bib = None
                skip_bib_prompt = False
                continue
            while True:
                options = [
                    ("frames", "Browse saved full frames"),
                    ("video-last", "Open last sighting in video"),
                    ("summary", "Print recent evidence lines"),
                    ("another", "Look up another bib"),
                ]
                if sighting_span_seconds(matches) >= 60.0:
                    options.insert(1, ("video-first", "Open first sighting in video"))
                chosen_mode = prompt_review_action_or_bib(
                    options,
                    default_value="frames",
                )
                if chosen_mode is None:
                    return 0
                print()
                if chosen_mode.startswith("bib:"):
                    current_bib = chosen_mode[4:]
                    skip_bib_prompt = True
                    break
                if chosen_mode == "another":
                    current_bib = None
                    skip_bib_prompt = False
                    break
                status = run_review_bib_action(
                    args=args,
                    session_dir=session_dir,
                    normalized_bib=scope_label,
                    matches=matches,
                    mode=chosen_mode,
                )
                print()
                if status != 0:
                    return status
        return 0
    if mode == "interactive":
        mode = "video-last"

    if not args.bib:
        print("review-bib requires a bib unless interactive prompts are enabled", file=sys.stderr)
        return 1

    if is_all_review_selector(args.bib):
        normalized_bib = "all"
        matches = load_all_evidence_matches(session_dir)
        summary_lines = all_match_summary_lines(session_dir, matches) if matches else []
    else:
        normalized_bib = normalize_bib_text(args.bib)
        if not normalized_bib:
            print(f"not a bib-like lookup value: {args.bib}", file=sys.stderr)
            return 1
        matches = load_evidence_matches_for_bib(session_dir, normalized_bib)
        summary_lines = bib_match_summary_lines(session_dir, normalized_bib, matches) if matches else []
    if not matches:
        if normalized_bib == "all":
            print(f"no evidence events found in {session_dir}", file=sys.stderr)
        else:
            print(f"no evidence events found for bib {normalized_bib} in {session_dir}", file=sys.stderr)
        return 1

    for line in summary_lines:
        print(line)
    print()

    return run_review_bib_action(
        args=args,
        session_dir=session_dir,
        normalized_bib=normalized_bib,
        matches=matches,
        mode=mode,
    )


def resolve_evidence_session_from_args(args: argparse.Namespace, purpose: str) -> Path | None:
    config_path = args.config_file.expanduser()
    config = load_config(config_path)
    if not getattr(args, "target", None) and interactive_mode_enabled(args):
        selected_target = select_session_target(
            args,
            config,
            title=f"Choose a session for {purpose}",
        )
        if not selected_target:
            print(f"no sessions found for {purpose}", file=sys.stderr)
            return None
        args.target = Path(selected_target)

    try:
        session_dir = resolve_session_dir(
            args.recordings_dir.expanduser(),
            str(args.target) if getattr(args, "target", None) else None,
        )
    except FileNotFoundError as exc:
        print(exc, file=sys.stderr)
        return None

    config["last_session_dir"] = str(session_dir)
    save_config(config_path, config)
    return session_dir


def command_record(args: argparse.Namespace) -> int:
    return run_record_command(args, launch_player=False)


def command_go(args: argparse.Namespace) -> int:
    return run_record_command(args, launch_player=True)


def command_watch(args: argparse.Namespace) -> int:
    config_path = args.config_file.expanduser()
    config = load_config(config_path)
    if not args.target and interactive_mode_enabled(args):
        selected_target = select_watch_target(args, config)
        if not selected_target:
            print("no sessions found to watch", file=sys.stderr)
            return 1
        args.target = selected_target

    player = choose_player(args.player)
    if not player:
        requested = args.player or "vlc/mpv/ffplay"
        print(f"player not found: {requested}", file=sys.stderr)
        return 1

    try:
        target_path = resolve_watch_target(args.recordings_dir.expanduser(), args.target)
    except FileNotFoundError as exc:
        print(exc, file=sys.stderr)
        return 1

    if not target_path.exists():
        print(f"watch target not found: {target_path}", file=sys.stderr)
        return 1

    command = build_player_command(player, target_path, args.file_caching_ms)
    print("Player:", shlex.join(command))
    if args.dry_run:
        return 0

    config["last_session_dir"] = str(target_path.parent if target_path.is_file() else target_path)
    save_config(config_path, config)
    return subprocess.call(command)


def command_export(args: argparse.Namespace) -> int:
    config_path = args.config_file.expanduser()
    config = load_config(config_path)
    if not args.target and interactive_mode_enabled(args):
        selected_target = select_export_target(args, config)
        if not selected_target:
            print("no sessions found to export", file=sys.stderr)
            return 1
        args.target = selected_target

    try:
        source = resolve_export_source(args.recordings_dir.expanduser(), args.target)
    except FileNotFoundError as exc:
        print(exc, file=sys.stderr)
        return 1

    if not source.source_path.exists():
        print(f"export source not found: {source.source_path}", file=sys.stderr)
        return 1

    ffmpeg_path, supported_encoders = detect_supported_encoders(args.ffmpeg_bin)
    if not ffmpeg_path:
        print(f"ffmpeg binary not found: {args.ffmpeg_bin}", file=sys.stderr)
        return 1

    duration_seconds = probe_media_duration(args.ffmpeg_bin, source.source_path)
    session_metadata = load_session_metadata(source.session_dir)

    if interactive_mode_enabled(args) and not args.preset:
        args.preset = choose_export_preset(
            duration_seconds, default_preset=config.get("last_export_preset")
        )

    preset_name = args.preset or "share-medium"
    if preset_name not in EXPORT_PRESETS:
        print(f"unknown export preset: {preset_name}", file=sys.stderr)
        return 1

    output_path = export_output_path(
        source.session_dir, preset_name, args.output, session_metadata
    )
    preset = EXPORT_PRESETS[preset_name]
    total_mbps = preset_total_mbps(preset_name)
    export_encoder, export_preset, export_encoder_reason = resolve_export_encoder(
        supported_encoders, session_metadata
    )
    if not export_encoder:
        print("no supported export video encoder found for this ffmpeg build", file=sys.stderr)
        return 1
    estimated_size = estimate_size_bytes(duration_seconds, total_mbps)
    export_command = build_export_command(
        ffmpeg_path,
        source.source_path,
        output_path,
        preset_name,
        export_encoder,
        export_preset,
    )

    print("Export summary")
    print(f"  Source:      {source.source_path}")
    print(f"  Preset:      {preset['label']}")
    print(f"  Encoder:     {export_encoder} ({export_encoder_reason})")
    print(f"  Output:      {output_path}")
    print(f"  Duration:    {format_duration(duration_seconds)}")
    print(
        "  Est. size:   "
        f"{format_bytes(estimated_size) if estimated_size is not None else 'unknown'}"
    )

    if interactive_mode_enabled(args):
        print()
        if not prompt_yes_no("Start export now?", default=True):
            return 0

    print("Export:", shlex.join(export_command))
    if args.dry_run:
        return 0

    ensure_directory(output_path.parent)
    result = subprocess.run(export_command, check=False)
    if result.returncode != 0:
        return result.returncode
    if not output_path.exists():
        print(f"export did not create output: {output_path}", file=sys.stderr)
        return 1

    config["last_session_dir"] = str(source.session_dir)
    config["last_export_preset"] = preset_name
    save_config(config_path, config)
    export_metadata = {
        "created_at": datetime.now().astimezone().isoformat(),
        "source_path": str(source.source_path),
        "source_label": source.source_label,
        "preset": preset_name,
        "encoder": export_encoder,
        "encoder_preset": export_preset,
        "encoder_reason": export_encoder_reason,
        "duration_seconds": duration_seconds,
        "estimated_size_bytes": estimated_size,
        "output_path": str(output_path),
        "output_size_bytes": output_path.stat().st_size,
        "ffmpeg_command": export_command,
    }
    try:
        export_metadata_path(output_path).write_text(
            json.dumps(export_metadata, indent=2) + "\n"
        )
    except OSError as exc:
        print(f"warning: could not write export metadata: {exc}", file=sys.stderr)
    print("Export complete")
    print(f"  File:  {output_path}")
    print(f"  Size:  {format_bytes(output_path.stat().st_size)}")
    return 0


def check_ffmpeg_support(ffmpeg_bin: str) -> tuple[str | None, bool]:
    ffmpeg_path, supported_encoders = detect_supported_encoders(ffmpeg_bin)
    return ffmpeg_path, "h264_nvenc" in supported_encoders


def command_doctor(args: argparse.Namespace) -> int:
    ffmpeg_path, supported_encoders = detect_supported_encoders(args.ffmpeg_bin)
    has_nvenc = "h264_nvenc" in supported_encoders
    resolved_encoder = resolve_encoder(ffmpeg_path, supported_encoders, args.encoder)
    player = choose_player(args.player)
    device_exists = Path(args.device).exists()
    audio_ok = alsa_device_exists(args.audio_device) if args.audio else True

    print(f"ffmpeg:   {ffmpeg_path or 'missing'}")
    print(f"nvenc:    {'yes' if has_nvenc else 'no'}")
    print(f"encoder:  {resolved_encoder or 'missing'}")
    print(f"player:   {player or 'missing'}")
    print(f"device:   {args.device} ({'ok' if device_exists else 'missing'})")
    print(
        f"audio:    {args.audio_device if args.audio else 'disabled'} "
        f"({'ok' if audio_ok else 'missing'})"
    )
    print(f"outputs:  {args.recordings_dir.expanduser()}")

    if not ffmpeg_path or not resolved_encoder or not device_exists or not audio_ok:
        return 1
    return 0


