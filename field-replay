        f"zone {motion_zone_label(candidate.get('zone'))})"
    )


def choose_motion_candidate(
    title: str,
    candidates: Sequence[dict],
) -> dict | None:
    if not candidates:
        return None
    options = [
        (str(index), motion_candidate_summary_line(candidate))
        for index, candidate in enumerate(candidates, start=1)
    ]
    choice = prompt_menu(title, options, default_value="1", allow_cancel=True)
    if choice is None:
        return None
    return candidates[int(choice) - 1]


def prompt_motion_feedback() -> str | None:
    choices = {
        "g": "good catch",
        "f": "false positive",
        "m": "missed event nearby",
        "s": "skip",
        "q": "quit",
    }
    choice = prompt_choice("Feedback", choices, default="g")
    if choice == "q":
        return None
    labels = {
        "g": "good",
        "f": "false-positive",
        "m": "missed",
        "s": "skip",
    }
    return labels[choice]


