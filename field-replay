def media_sample_points(duration_seconds: float, sample_interval: float) -> list[float]:
    sample_interval = max(sample_interval, 0.1)
    if duration_seconds <= 0:
        return [0.0]
    sample_points: list[float] = []
    current = 0.0
    while current <= duration_seconds + 0.001:
        sample_points.append(round(current, 3))
        current += sample_interval
    return sample_points


