        options.append((current_device, f"{current_device} (current/custom)"))
    options.append(("__custom__", "Enter a custom video device path"))
    choice = prompt_menu("Video source", options, default_value=current_device)
    if choice == "__custom__":
        return prompt_text("Video device path", current_device)
