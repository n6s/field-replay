    find_bib.add_argument("bib", help="Bib number or PACER token to search for.")
    find_bib.add_argument(
        "target",
        nargs="?",
        type=Path,
        help="Optional session directory. Defaults to an interactive picker or the latest session.",
    )
    find_bib.add_argument(
        "--limit",
        type=int,
        default=10,
        help="Maximum number of matching evidence lines to print.",
    )
    find_bib.add_argument(
        "--interactive",
        action=argparse.BooleanOptionalAction,
        default=True,
        help="Prompt to choose a recent session when the target is omitted.",
    )
    find_bib.set_defaults(func=command_find_bib)

    review_bib = subparsers.add_parser(
        "review-bib",
        help="Open vision evidence for one bib in video or saved images.",
    )
    review_bib.add_argument(
        "bib",
        nargs="?",
        help="Bib number or PACER token to review. Interactive mode can prompt for this.",
    )
    review_bib.add_argument(
        "target",
        nargs="?",
        type=Path,
        help="Optional session directory. Defaults to an interactive picker or the latest session.",
    )
    review_bib.add_argument(
        "--mode",
        default="interactive",
        help="Review action: interactive, video-first, video-last, frames, or summary. Defaults to an interactive menu.",
    )
    review_bib.add_argument(
        "--player",
        help="Preferred player for video review. Defaults to vlc, then mpv, ffplay, cvlc.",
    )
    review_bib.add_argument(
        "--image-viewer",
        help="Preferred image viewer for frame browsing. Defaults to eog.",
    )
    review_bib.add_argument(
        "--pre-roll",
        type=float,
        default=2.0,
        help="Seconds to rewind before opening a video sighting.",
    )
    review_bib.add_argument(
        "--limit",
        type=int,
        default=10,
        help="Maximum number of evidence lines to print when using summary mode.",
    )
    review_bib.add_argument(
        "--file-caching-ms",
        type=int,
        default=300,
        help="Player file cache in milliseconds for video review.",
    )
    review_bib.add_argument(
        "--dry-run",
        action="store_true",
        help="Print the player or image-viewer command without running it.",
    )
    review_bib.add_argument(
        "--interactive",
        action=argparse.BooleanOptionalAction,
        default=True,
        help="Prompt to choose a recent session or review action when arguments are omitted.",
    )
    review_bib.set_defaults(func=command_review_bib)

    doctor = subparsers.add_parser(
        "doctor", help="Check the main dependencies and device path."
    )
    doctor.add_argument("--device", default="/dev/video2", help="Video device path.")
    doctor.add_argument(
        "--audio",
        action=argparse.BooleanOptionalAction,
        default=True,
        help="Check the configured audio capture device too.",
    )
    doctor.add_argument(
        "--audio-device",
        default="hw:Capture,0",
        help="ALSA capture device to check.",
    )
    doctor.add_argument(
        "--player",
        help="Preferred player to check. Defaults to vlc, then mpv, ffplay, cvlc.",
    )
    doctor.add_argument(
        "--encoder",
        default=DEFAULT_ENCODER,
        help="Preferred video encoder to validate, with automatic fallback.",
    )
    doctor.set_defaults(func=command_doctor)

    return parser


def main(argv: Sequence[str] | None = None) -> int:
    parser = build_parser()
    args = parser.parse_args(argv)
    return args.func(args)


if __name__ == "__main__":
    try:
        raise SystemExit(main())
    except KeyboardInterrupt:
        print()
        raise SystemExit(130)
