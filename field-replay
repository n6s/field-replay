            runtime_paths[key].unlink()
        except FileNotFoundError:
            pass

    config["last_session_dir"] = str(source.session_dir)
    save_config(config_path, config)

    duration_seconds = probe_media_duration(args.ffmpeg_bin, source.source_path) or 0.0
    sample_points = media_sample_points(duration_seconds, args.sample_interval)
    if args.max_samples is not None:
        sample_points = sample_points[: max(args.max_samples, 0)]
    prompt = args.prompt or default_vision_prompt()

    print(f"Vision scan source: {source.source_path}")
    print(f"Vision output dir:  {output_root}")
    print(f"Vision model:       {args.model}")
    print(f"Samples:            {len(sample_points)}")
    print(f"Repeat cooldown:    {args.repeat_cooldown:.0f}s")
    if args.dry_run:
        for offset_seconds in sample_points:
            print(f"  sample {format_duration(offset_seconds)}")
        return 0

