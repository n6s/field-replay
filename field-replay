def configure_record_interactively(
    args: argparse.Namespace,
    config: dict,
    *,
    choose_profile: bool = True,
    selected_profile_name: str | None = None,
) -> None:
    profiles = config.get("profiles", {})

    if choose_profile and profiles:
        selected_profile_name = choose_saved_profile(
            config, preferred_profile=args.profile
        )
        if selected_profile_name:
            apply_profile(args, profiles[selected_profile_name])
            config["last_profile"] = selected_profile_name
    elif selected_profile_name and selected_profile_name in profiles:
        config["last_profile"] = selected_profile_name

    print()
    args.device = select_video_device(args.device)
    print()
    args.audio, args.audio_device = select_audio_source(args.audio, args.audio_device)
    print()
    args.recordings_dir = select_storage_path(args.recordings_dir.expanduser())

    print()
    print("Recording summary")
    print(f"  Video:   {args.device}")
    print(
        f"  Format:  {args.video_input_format if args.video_input_format != DEFAULT_VIDEO_INPUT_FORMAT else 'auto'}"
    )
    print(f"  Audio:   {args.audio_device if args.audio else 'disabled'}")
    print(f"  Storage: {storage_summary(args.recordings_dir)}")
    print(
        "  Stamp:   "
        f"{'wall-clock overlay' if args.video_timestamp else 'disabled'}"
    )

    if selected_profile_name:
        if prompt_yes_no(f"Update saved profile '{selected_profile_name}' with these settings?", default=False):
            profiles[selected_profile_name] = profile_from_args(args)
            config["last_profile"] = selected_profile_name
    elif prompt_yes_no("Save this setup as a reusable profile?", default=False):
        while True:
            profile_name = prompt_text("Profile name")
            if not profile_name:
                print("Profile name cannot be blank.")
                continue
            profiles[profile_name] = profile_from_args(args)
            config["last_profile"] = profile_name
            break

    config["profiles"] = profiles
    config["last_recordings_dir"] = str(args.recordings_dir.expanduser())


def ensure_profile_name(config: dict, existing_name: str | None = None) -> str:
    if existing_name:
