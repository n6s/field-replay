        options,
        default_value=str(current_dir.expanduser()),
    )
    if choice == "__custom__":
        return Path(prompt_text("Recordings directory", str(current_dir.expanduser()))).expanduser()
    return Path(choice).expanduser()


def known_recordings_roots(args: argparse.Namespace, config: dict) -> list[Path]:
    candidates = [args.recordings_dir.expanduser()]
    last_root = config.get("last_recordings_dir")
    if last_root:
        candidates.append(Path(last_root).expanduser())
    for profile in config.get("profiles", {}).values():
        recordings_dir = profile.get("recordings_dir")
        if recordings_dir:
            candidates.append(Path(recordings_dir).expanduser())

    unique: list[Path] = []
    seen: set[str] = set()
    for path in candidates:
        key = str(path)
        if key not in seen:
            seen.add(key)
            unique.append(path)
    return unique


