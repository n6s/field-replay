def resolve_watch_target(recordings_dir: Path, target: str | None) -> Path:
    if target:
        resolved = Path(target).expanduser()
        if resolved.is_dir():
            timeshift = resolved / DEFAULT_TIMESHIFT_NAME
            archive_mkv = resolved / f"{DEFAULT_ARCHIVE_STEM}.mkv"
            archive_mp4 = resolved / f"{DEFAULT_ARCHIVE_STEM}.mp4"
            if timeshift.exists():
                return timeshift
            if archive_mkv.exists():
                return archive_mkv
            if archive_mp4.exists():
                return archive_mp4
            raise FileNotFoundError(f"no watchable media found under {resolved}")
        return resolved

    latest_link = recordings_dir / "latest"
    if not latest_link.exists():
        raise FileNotFoundError(
            f"no latest session found under {recordings_dir}; run record first"
        )
    resolved = latest_link.resolve()
    timeshift = resolved / DEFAULT_TIMESHIFT_NAME
    archive_mkv = resolved / f"{DEFAULT_ARCHIVE_STEM}.mkv"
    archive_mp4 = resolved / f"{DEFAULT_ARCHIVE_STEM}.mp4"
    if timeshift.exists():
        return timeshift
    if archive_mkv.exists():
        return archive_mkv
    if archive_mp4.exists():
        return archive_mp4
    raise FileNotFoundError(f"no watchable media found under {resolved}")


def resolve_session_dir(recordings_dir: Path, target: str | None) -> Path:
    if target:
        resolved = Path(target).expanduser()
        if resolved.is_dir():
            return resolved
        if resolved.is_file():
            return resolved.parent
        raise FileNotFoundError(f"session target not found: {resolved}")

    latest_link = recordings_dir / "latest"
    if not latest_link.exists():
        raise FileNotFoundError(
            f"no latest session found under {recordings_dir}; run record first"
        )
    resolved = latest_link.resolve()
    if not resolved.is_dir():
        raise FileNotFoundError(f"latest session is not a directory: {resolved}")
    return resolved


def resolve_export_source(recordings_dir: Path, target: str | None) -> ExportSource:
    if target:
        resolved = Path(target).expanduser()
        if resolved.is_dir():
            source = export_source_for_session(resolved)
            if source:
                return source
            raise FileNotFoundError(f"no exportable media found under {resolved}")
        if not resolved.exists():
            raise FileNotFoundError(f"export source not found: {resolved}")
        return ExportSource(
            session_dir=resolved.parent,
            source_path=resolved,
            source_label=resolved.name,
        )

    latest_link = recordings_dir / "latest"
    if not latest_link.exists():
        raise FileNotFoundError(
            f"no latest session found under {recordings_dir}; run record first"
        )
    session_dir = latest_link.resolve()
    source = export_source_for_session(session_dir)
    if source:
        return source
    raise FileNotFoundError(f"no exportable media found under {session_dir}")


def probe_media_duration(ffmpeg_bin: str, source_path: Path) -> float | None:
    ffprobe_bin = "ffprobe"
    ffmpeg_path = shutil.which(ffmpeg_bin)
    if ffmpeg_path:
        ffprobe_bin = str(Path(ffmpeg_path).with_name("ffprobe"))
    ffprobe_path = shutil.which(ffprobe_bin) or (ffprobe_bin if Path(ffprobe_bin).exists() else None)
    if not ffprobe_path:
        return None

    result = subprocess.run(
        [
            ffprobe_path,
            "-v",
            "error",
            "-show_entries",
            "format=duration",
            "-of",
            "default=noprint_wrappers=1:nokey=1",
            str(source_path),
        ],
        capture_output=True,
        text=True,
        check=False,
    )
    if result.returncode != 0:
        return None
    try:
        return float(result.stdout.strip())
    except ValueError:
        return None


