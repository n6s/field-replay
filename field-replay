def command_setup(args: argparse.Namespace) -> int:
    config_path = args.config_file.expanduser()
    config = load_config(config_path)
    profiles = config.get("profiles", {})

    selected_profile_name = args.profile
    if interactive_mode_enabled(args):
        selected_profile_name = choose_saved_profile(
            config,
            default_manual=not bool(args.profile),
            preferred_profile=args.profile,
        )

    if selected_profile_name and selected_profile_name in profiles:
        apply_profile(args, profiles[selected_profile_name])
    elif not interactive_mode_enabled(args) and not args.dry_run and not selected_profile_name:
        print(
            "setup --no-interactive requires --profile for the saved profile name",
            file=sys.stderr,
        )
        return 1

    if interactive_mode_enabled(args):
        print()
        args.source_type = select_source_type(args.source_type)
        print()
        if is_rtsp_source(args):
            args.rtsp_url = select_rtsp_url(args.rtsp_url)
            print()
            args.rtsp_transport = select_rtsp_transport(args.rtsp_transport)
            print()
            args.audio = prompt_yes_no(
                "Capture embedded stream audio if present?", default=args.audio
            )
        else:
            args.device = select_video_device(args.device)
            print()
            args.audio, args.audio_device = select_audio_source(args.audio, args.audio_device)
        print()
        if args.audio:
            args.audio_gain_db = prompt_float("Audio gain (dB)", args.audio_gain_db)
            print()
        args.recordings_dir = select_storage_path(args.recordings_dir.expanduser())
        print()

    source_error = validate_source_args(args)
    if source_error:
        print(source_error, file=sys.stderr)
        return 1

    for warning in auto_select_video_codec_mode(args):
        print(f"warning: {warning}", file=sys.stderr)

    ffmpeg_path, supported_encoders = detect_supported_encoders(args.ffmpeg_bin)
    if not uses_video_passthrough(args):
        resolved_encoder = resolve_encoder(ffmpeg_path, supported_encoders, args.encoder)
        if resolved_encoder:
            args.encoder = resolved_encoder

    if args.probe:
        if not ffmpeg_path:
            print(f"ffmpeg binary not found: {args.ffmpeg_bin}", file=sys.stderr)
            return 1

        if is_rtsp_source(args):
            print(
                "RTSP source probing is not implemented yet. Keeping the configured stream settings."
            )
        else:
            print(f"Probing video modes for {args.device}...")
            selected_size, selected_fps, selected_format, video_results, video_failure = choose_video_profile_settings(
                ffmpeg_path,
                args.device,
                args.video_size,
                args.framerate,
                args.video_input_format,
                stop_on_exact=not interactive_mode_enabled(args),
            )
            if video_results:
                if interactive_mode_enabled(args):
                    chosen_result = choose_video_probe_result(
                        video_results,
                        current_size=args.video_size,
                        current_fps=args.framerate,
                        current_input_format=args.video_input_format,
                    )
                    if chosen_result:
                        args.video_size = chosen_result["actual_size"]
                        args.framerate = int(round(chosen_result["actual_fps"]))
                        args.video_input_format = chosen_result["input_format"]
                    else:
                        args.video_size = selected_size
                        args.framerate = selected_fps
                        args.video_input_format = selected_format
                else:
                    print_video_probe_results(video_results)
                    args.video_size = selected_size
                    args.framerate = selected_fps
                    args.video_input_format = selected_format
            else:
                print("Video probe did not find a better mode. Keeping current defaults.")
                if video_failure:
                    print(f"  Probe detail: {video_failure}")

            if args.audio:
                print()
                print(f"Probing audio input modes for {args.audio_device}...")
                input_rate, input_channels, audio_results, audio_failure = choose_audio_profile_settings(
                    ffmpeg_path, args.audio_device, args.audio_input_rate, args.audio_input_channels
                )
                if audio_results:
                    print_audio_probe_results(audio_results)
                    args.audio_input_rate = input_rate
                    args.audio_input_channels = input_channels
                else:
                    print("Audio probe did not find a working input mode. Audio will stay as configured.")
                    if audio_failure:
                        print(f"  Probe detail: {audio_failure}")

        print()

    for warning in normalize_video_settings(args):
        print(f"warning: {warning}", file=sys.stderr)

    print("Setup summary")
    print(f"  Source type:       {args.source_type}")
    print(f"  Video source:      {source_display_label(args)}")
    if is_rtsp_source(args):
        print(f"  RTSP transport:    {args.rtsp_transport}")
    print(
        f"  Video input fmt:   {args.video_input_format if args.video_input_format != DEFAULT_VIDEO_INPUT_FORMAT else 'auto'}"
    )
    print(f"  Video path:        {args.video_codec_mode}")
    if is_rtsp_source(args):
        print(f"  Output pacing:     target {args.framerate} fps")
    else:
        print(f"  Capture mode:      {args.video_size} @ {args.framerate} fps")
    if uses_alsa_audio_input(args):
        print(f"  Audio device:      {args.audio_device}")
        print(
            f"  Audio input mode:  {args.audio_input_rate} Hz, {args.audio_input_channels} channel(s)"
        )
        print(f"  Audio gain:        {args.audio_gain_db:g} dB")
    else:
        print(
            "  Audio source:      "
            f"{'embedded stream audio' if args.audio else 'disabled'}"
        )
        if args.audio:
            print(f"  Audio gain:        {args.audio_gain_db:g} dB")
    print(f"  Storage:           {storage_summary(args.recordings_dir)}")
    print(
        f"  Video encoder:     {'copy (passthrough)' if uses_video_passthrough(args) else args.encoder}"
    )
    print(
        "  Video timestamp:   "
        f"{'wall-clock overlay' if args.video_timestamp else 'disabled'}"
    )

    if args.dry_run:
        return 0

    if interactive_mode_enabled(args):
        print()
        if not prompt_yes_no("Save this setup?", default=True):
            return 0

    profile_name = ensure_profile_name(config, existing_name=selected_profile_name)
    profiles[profile_name] = profile_from_args(args)
    config["profiles"] = profiles
    config["last_profile"] = profile_name
    config["last_recordings_dir"] = str(args.recordings_dir.expanduser())
    save_config(config_path, config)
    print(f"Saved profile: {profile_name}")
    return 0


def list_session_dirs(recordings_root: Path) -> list[Path]:
    if not recordings_root.exists():
        return []
    sessions: list[Path] = []
    for child in sorted(recordings_root.iterdir()):
        if child.name == "latest":
            continue
        if not child.is_dir() or child.name.startswith("."):
            continue
        if (child / "session.json").exists() or (child / DEFAULT_TIMESHIFT_NAME).exists():
            sessions.append(child)
    return sessions


def recent_sessions(args: argparse.Namespace, config: dict) -> list[Path]:
    sessions: list[Path] = []
    for root in known_recordings_roots(args, config):
        sessions.extend(list_session_dirs(root))

    unique_sessions: list[Path] = []
    seen: set[str] = set()
    for session in sorted(sessions, key=lambda path: path.stat().st_mtime, reverse=True):
        try:
            canonical = str(session.resolve())
        except OSError:
            canonical = str(session)
        if canonical in seen:
            continue
        seen.add(canonical)
        unique_sessions.append(session)
    return unique_sessions


def session_target_summary(session_dir: Path) -> str:
    timeshift = session_dir / DEFAULT_TIMESHIFT_NAME
    archive_mkv = session_dir / f"{DEFAULT_ARCHIVE_STEM}.mkv"
    archive_mp4 = session_dir / f"{DEFAULT_ARCHIVE_STEM}.mp4"
    if timeshift.exists():
        return "DVR timeshift"
    if archive_mkv.exists():
        return "archive.mkv"
    if archive_mp4.exists():
        return "archive.mp4"
    return "session"


def session_display_label(session_dir: Path) -> str:
    metadata_path = session_dir / "session.json"
    state = "unknown"
    if metadata_path.exists():
        try:
            state = json.loads(metadata_path.read_text()).get("state", state)
        except (OSError, json.JSONDecodeError):
            state = "unknown"
    root_label = str(session_dir.parent)
    target_label = session_target_summary(session_dir)
    return f"{session_dir.name} [{target_label}; {state}; {root_label}]"


def select_watch_target(args: argparse.Namespace, config: dict) -> str | None:
    unique_sessions = recent_sessions(args, config)
    if not unique_sessions:
        return None
    options = [(str(path), session_display_label(path)) for path in unique_sessions[:20]]
    default_value = config.get("last_session_dir")
    return prompt_menu("Choose a session to watch", options, default_value=default_value)


def select_session_target(
    args: argparse.Namespace,
    config: dict,
    *,
    title: str = "Choose a session",
) -> str | None:
    unique_sessions = recent_sessions(args, config)
    if not unique_sessions:
        return None
    options = [(str(path), session_display_label(path)) for path in unique_sessions[:20]]
    options.append(("__manual__", "Enter a session path manually"))
    default_value = config.get("last_session_dir")
    choice = prompt_menu(title, options, default_value=default_value)
    if choice == "__manual__":
        return prompt_text("Session directory")
