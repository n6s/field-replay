def comparison_vision_prompt(base_prompt: str) -> str:
    bib_focused = prompt_seems_bib_focused(base_prompt)
    if bib_focused:
        example = '{"detections":[{"label":"<bib-number>","status":"unchanged"}]}'
    else:
        example = '{"detections":[{"label":"white pickup right","status":"unchanged"}]}'
    guidance = (
        "If the operator intent is bib tracking, return only exact bib numbers "
        "that are clearly visible on a person or race number card, and ignore "
        "unrelated background objects. Do not copy the example number or invent a "
        "bib when none is visible. If the operator intent is general scene "
        "monitoring, give each distinct car, person, pet, or other object a "
        "descriptive label that includes stable details such as color, type, and "
        "coarse position so a parked background vehicle does not mask a different "
        "passing one. Prefer a descriptive label such as 'white pickup right' or "
        "'person red shirt left' over a bare class label like 'car' unless no "
        "better detail is visible."
    )
    return (
        "You will receive two images from the same camera. Image 1 is the previous "
        "sample and image 2 is the current sample. Use this detection task as the "
        f"operator intent: {base_prompt}\n"
        "Ignore any return-format instructions inside the operator intent and use "
        f"the comparison JSON shape below. {guidance} "
        "Report only objects or labels that are visible in image 2. For each item, "
        "set status to one of new, moved, unchanged, or unclear compared with image 1. "
        "Use unchanged only when the same relevant object appears to still be in the "
        f"same place. Return only JSON in this exact shape: {example}. "
        'If there are no relevant current detections, return {"detections":[]}.'
    )


def extract_json_object(text: str) -> dict:
    stripped = text.strip()
    try:
        payload = json.loads(stripped)
    except json.JSONDecodeError:
        start = stripped.find("{")
        end = stripped.rfind("}")
        if start == -1 or end == -1 or end <= start:
            return {}
        try:
            payload = json.loads(stripped[start : end + 1])
        except json.JSONDecodeError:
            return {}
    return payload if isinstance(payload, dict) else {}


UNCHANGED_COMPARISON_STATUSES = {
    "same",
    "static",
    "stationary",
    "unchanged",
    "unmoved",
    "no-change",
    "no_change",
}


def normalize_comparison_status(value: object) -> str | None:
    if value in (None, ""):
        return None
    status = normalize_detection_text(str(value)).replace(" ", "-")
    status_aliases = {
        "changed": "moved",
        "movement": "moved",
        "moving": "moved",
        "new-arrival": "new",
        "newly-visible": "new",
        "same-position": "unchanged",
        "still-present": "unchanged",
        "not-moved": "unchanged",
        "not_moved": "unchanged",
    }
    return status_aliases.get(status, status)


def add_detection_with_status(
    detections: list[str],
    status_by_detection: dict[str, str],
    raw_label: object,
    raw_status: object = None,
) -> None:
    detection = normalize_detection_text(str(raw_label))
    if not detection:
        return
    if detection not in detections:
        detections.append(detection)
    status = normalize_comparison_status(raw_status)
    if status:
        status_by_detection[detection] = status


def extract_detection_label_from_mapping(item: dict) -> object | None:
    for key in ("label", "l", "detection", "name", "type", "object", "bib", "b"):
        value = item.get(key)
        if value not in (None, ""):
            return value
    return None


def extract_detection_status_from_mapping(item: dict) -> object | None:
    for key in ("status", "state", "change", "movement", "motion"):
        value = item.get(key)
        if value not in (None, ""):
            return value
    return None


def normalize_vision_detections(payload: dict) -> list[str]:
    detections, _ = normalize_vision_detection_statuses(payload)
    return detections


def normalize_vision_detection_statuses(payload: dict) -> tuple[list[str], dict[str, str]]:
    raw_detections = payload.get("detections")
    if not isinstance(raw_detections, list):
        raw_detections = payload.get("labels")
    if not isinstance(raw_detections, list):
        raw_detections = payload.get("bibs")
    if not isinstance(raw_detections, list):
        raw_detections = []
    detections: list[str] = []
    status_by_detection: dict[str, str] = {}
    for raw_value in raw_detections:
        if isinstance(raw_value, dict):
            raw_label = extract_detection_label_from_mapping(raw_value)
            if raw_label is None:
                continue
            status = extract_detection_status_from_mapping(raw_value)
            normalized_status = normalize_comparison_status(status)
            if normalized_status in {"gone", "absent", "left", "removed"}:
                continue
            add_detection_with_status(
                detections,
                status_by_detection,
                raw_label,
                status,
            )
        else:
            add_detection_with_status(detections, status_by_detection, raw_value)

    status_lists = (
        ("unchanged", "unchanged"),
        ("same_static_objects", "unchanged"),
        ("stationary", "unchanged"),
        ("new", "new"),
        ("new_detections", "new"),
        ("moved", "moved"),
        ("changed", "moved"),
        ("unclear", "unclear"),
    )
    for key, status in status_lists:
        values = payload.get(key)
        if not isinstance(values, list):
            continue
        for raw_value in values:
            if isinstance(raw_value, dict):
                raw_label = extract_detection_label_from_mapping(raw_value)
                raw_status = extract_detection_status_from_mapping(raw_value) or status
            else:
                raw_label = raw_value
                raw_status = status
            if raw_label is not None:
                add_detection_with_status(
                    detections,
                    status_by_detection,
                    raw_label,
                    raw_status,
                )
    return detections, status_by_detection


def promoted_frame_path(
    runtime_paths: dict[str, Path], offset_seconds: float
) -> Path:
    stamp = f"{int(round(offset_seconds * 10)):010d}"
    return runtime_paths["frames_dir"] / f"frame-{stamp}.jpg"


def ffmpeg_drawtext_escape(text: str) -> str:
    return (
        text.replace("\\", r"\\")
        .replace(":", r"\:")
        .replace("'", r"\'")
        .replace("%", r"\%")
        .replace(",", r"\,")
    )


def annotate_promoted_frame(
    *,
    ffmpeg_bin: str,
    source_frame_path: Path,
    output_frame_path: Path,
    detected_labels: Sequence[str],
) -> None:
    label_text = "detections: " + ", ".join(detected_labels)
    filter_graph = (
        "drawtext="
        f"text='{ffmpeg_drawtext_escape(label_text)}':"
        "x=min(344\\,w-tw-20):y=h-th-20:"
        "box=1:boxcolor=0x00000099:boxborderw=10:"
        "fontcolor=white:fontsize=24:borderw=2"
    )
    ensure_directory(output_frame_path.parent)
    result = subprocess.run(
        [
            ffmpeg_bin,
            "-hide_banner",
            "-loglevel",
            "error",
            "-y",
            "-i",
            str(source_frame_path),
            "-vf",
            filter_graph,
            "-frames:v",
            "1",
            "-q:v",
            "2",
            str(output_frame_path),
        ],
        capture_output=True,
        text=True,
        check=False,
    )
    if result.returncode != 0:
        raise RuntimeError(result.stderr.strip() or "ffmpeg frame annotation failed")


def ask_ollama_for_detections(
    *,
    image_paths: Sequence[Path],
    model: str,
    ollama_host: str,
    prompt: str,
    timeout_seconds: float,
    keepalive: str,
) -> tuple[list[str], str, dict[str, str]]:
    encoded_images = [
        base64.b64encode(image_path.read_bytes()).decode("ascii")
        for image_path in image_paths
    ]
    request_payload = {
        "model": model,
        "prompt": prompt,
        "images": encoded_images,
        "stream": False,
        "format": "json",
        "keep_alive": keepalive,
        "options": {
            "temperature": 0,
            "top_p": 0.1,
        },
    }
    request_data = json.dumps(request_payload).encode("utf-8")
    endpoint = ollama_host.rstrip("/") + "/api/generate"
    request = urllib.request.Request(
        endpoint,
        data=request_data,
        headers={"Content-Type": "application/json"},
        method="POST",
    )
    try:
        with urllib.request.urlopen(request, timeout=timeout_seconds) as response:
            response_payload = json.loads(response.read().decode("utf-8"))
    except urllib.error.URLError as exc:
        raise RuntimeError(f"ollama request failed: {exc}") from exc
    except TimeoutError as exc:
        raise RuntimeError("ollama request timed out") from exc
    except json.JSONDecodeError as exc:
        raise RuntimeError(f"ollama returned invalid JSON: {exc}") from exc

    response_text = str(response_payload.get("response") or "")
    detections, status_by_detection = normalize_vision_detection_statuses(
        extract_json_object(response_text)
    )
    return detections, response_text, status_by_detection


def event_detection_label(event: dict) -> str | None:
    raw_value = event.get("l")
    if raw_value in (None, ""):
        raw_value = event.get("b")
    if raw_value in (None, ""):
        raw_value = event.get("label")
    if raw_value in (None, ""):
        return None
    return normalize_detection_text(str(raw_value))


def summarize_vision_scan_output(output_root: Path) -> dict:
    debug_records = load_jsonl_records(output_root / "vision-debug.jsonl")
    event_records = load_jsonl_records(output_root / "events.jsonl")
    elapsed_values = [
        int(record["elapsed_ms"])
        for record in debug_records
        if isinstance(record.get("elapsed_ms"), int)
    ]
    sample_detections_by_time: dict[str, list[str]] = {}
    for record in debug_records:
        time_key = f"{float(record.get('t') or 0.0):.3f}"
        detections = record.get("detections")
        if not isinstance(detections, list):
            detections = record.get("bibs")
        if isinstance(detections, list):
            sample_detections_by_time[time_key] = [
                normalized
                for item in detections
                if (normalized := normalize_detection_text(str(item)))
            ]
    unique_detections = sorted(
        {
            normalized
            for record in event_records
            if (normalized := event_detection_label(record))
        }
    )
    summary = {
        "samples": len(debug_records),
        "successful_samples": sum(
            1
            for record in debug_records
            if isinstance(record.get("detections"), list) or isinstance(record.get("bibs"), list)
        ),
        "samples_with_any_detection": sum(
            1
            for record in debug_records
            if (
                isinstance(record.get("detections"), list)
                and record["detections"]
            )
            or (
                isinstance(record.get("bibs"), list)
                and record["bibs"]
            )
        ),
        "error_count": sum(1 for record in debug_records if "error" in record),
        "promoted_total": len(event_records),
        "unique_detections": unique_detections,
        "unique_detection_count": len(unique_detections),
        "median_elapsed_ms": int(round(statistics.median(elapsed_values))) if elapsed_values else None,
        "p95_elapsed_ms": (
            int(round(statistics.quantiles(elapsed_values, n=20)[18]))
            if len(elapsed_values) >= 20
            else max(elapsed_values, default=None)
        ),
        "sample_detections_by_time": sample_detections_by_time,
    }
    summary["samples_with_any_bib"] = summary["samples_with_any_detection"]
    summary["unique_bibs"] = list(unique_detections)
    summary["unique_bib_count"] = summary["unique_detection_count"]
    summary["sample_bibs_by_time"] = dict(sample_detections_by_time)
    return summary


def compare_vision_summaries(reference_summary: dict, variant_summary: dict) -> dict:
    reference_bibs_by_time = (
        reference_summary.get("sample_detections_by_time")
        or reference_summary.get("sample_bibs_by_time")
        or {}
    )
    variant_bibs_by_time = (
        variant_summary.get("sample_detections_by_time")
        or variant_summary.get("sample_bibs_by_time")
        or {}
    )
    matched_instances = 0
    reference_instances = 0
    extra_instances = 0
    for time_key, reference_bibs in reference_bibs_by_time.items():
        reference_set = set(reference_bibs)
        variant_set = set(variant_bibs_by_time.get(time_key) or [])
        matched_instances += len(reference_set & variant_set)
        reference_instances += len(reference_set)
        extra_instances += len(variant_set - reference_set)
    reference_unique = set(
        reference_summary.get("unique_detections") or reference_summary.get("unique_bibs") or []
    )
    variant_unique = set(
        variant_summary.get("unique_detections") or variant_summary.get("unique_bibs") or []
    )
    matched_unique = len(reference_unique & variant_unique)
    return {
        "reference_unique_bib_count": len(reference_unique),
        "matched_unique_bib_count": matched_unique,
        "unique_recall": (
            round(matched_unique / len(reference_unique), 3) if reference_unique else None
        ),
        "reference_instances": reference_instances,
        "matched_instances": matched_instances,
        "instance_recall": (
            round(matched_instances / reference_instances, 3) if reference_instances else None
        ),
        "extra_instances_vs_reference": extra_instances,
    }


def write_vision_sweep_summary(
    output_root: Path,
    source_path: Path,
    sample_points: Sequence[float],
    results: Sequence[dict],
) -> tuple[Path, Path]:
    summary_json_path = output_root / "summary.json"
    summary_text_path = output_root / "summary.txt"
    payload = {
        "created_at": datetime.now().astimezone().isoformat(),
        "source_path": str(source_path),
        "sample_interval_seconds": (
            round(sample_points[1] - sample_points[0], 3) if len(sample_points) >= 2 else None
        ),
        "sample_points_seconds": [round(point, 3) for point in sample_points],
        "results": list(results),
        "notes": [
            "Reference comparisons use the first variant as a baseline, not ground truth.",
            "Frame scaling preserves aspect ratio and pads to the requested canvas when needed.",
        ],
    }
    summary_json_path.write_text(json.dumps(payload, indent=2) + "\n")

    lines = [
        "Vision Sweep Summary",
        f"Source: {source_path}",
        f"Samples: {len(sample_points)}",
        "",
        "Variant comparison",
    ]
    for result in results:
        summary = result["summary"]
        compare = result.get("compare_to_reference") or {}
        comparison_bits = []
        if compare.get("unique_recall") is not None:
            comparison_bits.append(f"unique recall {compare['unique_recall']:.0%}")
        if compare.get("instance_recall") is not None:
            comparison_bits.append(f"sample recall {compare['instance_recall']:.0%}")
        if compare.get("extra_instances_vs_reference") is not None:
            comparison_bits.append(
                f"extra sample hits {compare['extra_instances_vs_reference']}"
            )
        lines.append(
            "  "
            f"{result['label']}: unique {summary['unique_detection_count']}, "
            f"promoted {summary['promoted_total']}, "
            f"samples-with-detections {summary['samples_with_any_detection']}, "
            f"median {summary['median_elapsed_ms'] or 0} ms"
            + (f" ({', '.join(comparison_bits)})" if comparison_bits else "")
        )
    lines.extend(
        [
            "",
            "Reference comparisons use the first variant as a baseline, not ground truth.",
        ]
    )
    summary_text_path.write_text("\n".join(lines) + "\n")
    return summary_json_path, summary_text_path


def process_vision_frame(
    *,
    runtime_paths: dict[str, Path],
    session_dir: Path,
    frame_path: Path,
    comparison_frame_path: Path | None = None,
    ffmpeg_bin: str,
    annotate_frames: bool,
    offset_seconds: float,
    model: str,
    ollama_host: str,
    prompt: str,
    timeout_seconds: float,
    keepalive: str,
    repeat_cooldown_seconds: float,
    last_promoted_by_key: dict[str, float],
) -> VisionFrameResult:
    now = datetime.now().astimezone()
    started_at = time.perf_counter()
    frame_reference = relative_to_session(frame_path, session_dir)
    image_paths = [frame_path]
    if comparison_frame_path is not None:
        image_paths = [comparison_frame_path, frame_path]
    comparison_frame_reference = (
        relative_to_session(comparison_frame_path, session_dir)
        if comparison_frame_path is not None
        else None
    )
    try:
        detections, response_text, status_by_detection = ask_ollama_for_detections(
            image_paths=image_paths,
            model=model,
            ollama_host=ollama_host,
            prompt=prompt,
            timeout_seconds=timeout_seconds,
            keepalive=keepalive,
        )
        elapsed_ms = int(round((time.perf_counter() - started_at) * 1000))
        promoted: list[dict] = []
        suppressed: list[str] = []
        unchanged_suppressed: list[str] = []
        promoted_frame_reference: str | None = None
        for detection in detections:
            comparison_status = status_by_detection.get(detection)
            promotion_key = detection_promotion_key(
                detection,
                comparison_status,
                compare_mode=comparison_frame_path is not None,
            )
            last_promoted_offset = last_promoted_by_key.get(promotion_key)
            if (
                comparison_frame_path is not None
                and comparison_status in UNCHANGED_COMPARISON_STATUSES
                and last_promoted_offset is not None
            ):
                suppressed.append(detection)
                unchanged_suppressed.append(detection)
                continue
            if (
                repeat_cooldown_seconds > 0
                and last_promoted_offset is not None
                and (offset_seconds - last_promoted_offset) < repeat_cooldown_seconds
            ):
                suppressed.append(detection)
                continue
            if promoted_frame_reference is None:
                saved_frame_path = promoted_frame_path(runtime_paths, offset_seconds)
                ensure_directory(saved_frame_path.parent)
                if annotate_frames:
                    try:
                        annotate_promoted_frame(
                            ffmpeg_bin=ffmpeg_bin,
                            source_frame_path=frame_path,
                            output_frame_path=saved_frame_path,
                            detected_labels=detections,
                        )
                    except RuntimeError:
                        shutil.copy2(frame_path, saved_frame_path)
                else:
                    shutil.copy2(frame_path, saved_frame_path)
                promoted_frame_reference = relative_to_session(saved_frame_path, session_dir)
            payload = {
                "t": round(offset_seconds, 1),
                "w": event_wall_time(now),
                "k": "detection",
                "l": detection,
                "s": "vision",
                "m": model,
                "f": promoted_frame_reference,
            }
            if is_bib_detection_label(detection):
                payload["b"] = detection
            append_jsonl(runtime_paths["events_jsonl"], payload)
            append_text_line(runtime_paths["events_log"], vision_event_log_line(payload))
            promoted.append(payload)
            last_promoted_by_key[promotion_key] = offset_seconds
        append_jsonl(
            runtime_paths["debug_log"],
            {
                "w": event_wall_time(now),
                "t": round(offset_seconds, 1),
                "model": model,
                "frame": frame_reference,
                "frames": [
                    relative_to_session(image_path, session_dir)
                    for image_path in image_paths
                ],
                "elapsed_ms": elapsed_ms,
                "response": response_text,
                "detections": detections,
                "bibs": [item for item in detections if is_bib_detection_label(item)],
                "promoted": [event_detection_label(payload) for payload in promoted],
                "suppressed": suppressed,
                "status_by_detection": status_by_detection,
                "comparison": {
                    "enabled": comparison_frame_path is not None,
                    "previous_frame": comparison_frame_reference,
                    "unchanged_suppressed": unchanged_suppressed,
                },
                "repeat_cooldown_s": repeat_cooldown_seconds,
            },
        )
        return VisionFrameResult(
            promoted=promoted,
            detections=detections,
            elapsed_ms=elapsed_ms,
            suppressed=suppressed,
            status_by_detection=status_by_detection,
            unchanged_suppressed=unchanged_suppressed,
            error=None,
        )
    except RuntimeError as exc:
        elapsed_ms = int(round((time.perf_counter() - started_at) * 1000))
        append_jsonl(
            runtime_paths["debug_log"],
            {
                "w": event_wall_time(now),
                "t": round(offset_seconds, 1),
                "frame": frame_reference,
                "frames": [
                    relative_to_session(image_path, session_dir)
                    for image_path in image_paths
                ],
                "elapsed_ms": elapsed_ms,
                "error": str(exc),
                "comparison": {
                    "enabled": comparison_frame_path is not None,
                    "previous_frame": comparison_frame_reference,
                },
            },
        )
        return VisionFrameResult(
            promoted=[],
            detections=[],
            elapsed_ms=elapsed_ms,
            suppressed=[],
            status_by_detection={},
            unchanged_suppressed=[],
            error=str(exc),
        )


def motion_summary_text(result: MotionSampleResult) -> str:
    if not result.enabled:
        return "motion gate disabled"
    if result.mean_diff is None or result.changed_pct is None:
        return "motion warm-up"
    return (
        f"motion mean {result.mean_diff:.1f}, "
        f"changed {result.changed_pct:.1f}% ({result.reason})"
    )


