def suggest_motion_setting_updates(
    feedback_records: Sequence[dict],
    *,
    current_threshold: float,
    current_consecutive: int,
    calibration_summary: dict | None = None,
) -> dict:
    suggested_threshold = float(current_threshold)
    suggested_consecutive = int(current_consecutive)
    reasons: list[str] = []
    good_count = sum(1 for item in feedback_records if item.get("feedback") == "good")
    false_positive_count = sum(
        1 for item in feedback_records if item.get("feedback") == "false-positive"
    )
    missed_count = sum(1 for item in feedback_records if item.get("feedback") == "missed")

    if missed_count > false_positive_count:
        if suggested_consecutive > 1:
            suggested_consecutive -= 1
            reasons.append("Lower consecutive hits because missed events outweighed false positives.")
        else:
            floor_threshold = 1.0
            if calibration_summary:
                p95_mean = calibration_summary.get("mean_p95")
                if p95_mean is not None:
                    floor_threshold = max(float(p95_mean) + 0.5, 1.0)
            lowered_threshold = max(floor_threshold, suggested_threshold - 1.0)
            if lowered_threshold < suggested_threshold:
                suggested_threshold = round(lowered_threshold, 1)
                reasons.append("Lower mean threshold because missed events outweighed false positives.")

    if false_positive_count > missed_count:
        suggested_threshold = round(suggested_threshold + 1.0, 1)
        reasons.append("Raise mean threshold because false positives outweighed misses.")
        if false_positive_count >= 2 and suggested_consecutive < 2:
            suggested_consecutive = 2
            reasons.append("Require two hits again because multiple false positives were flagged.")

    if not reasons and good_count:
        reasons.append("Keep the current settings for now; the reviewed events looked useful.")

    return {
        "good": good_count,
        "false_positive": false_positive_count,
        "missed": missed_count,
        "suggested_threshold": suggested_threshold,
        "suggested_consecutive": suggested_consecutive,
        "reasons": reasons,
    }


def run_motion_tune_candidate_review(
    *,
    args: argparse.Namespace,
    session_dir: Path,
    runtime_paths: dict[str, Path],
    profile_name: str | None,
    candidate: dict,
) -> str | None:
    player = choose_player(args.player)
    if not player:
        requested = args.player or "vlc/mpv/ffplay"
        print(f"player not found: {requested}", file=sys.stderr)
        return None
    try:
        target_path = resolve_watch_target(
            args.recordings_dir.expanduser(),
            str(session_dir),
        )
    except FileNotFoundError as exc:
        print(exc, file=sys.stderr)
        return None

    start_seconds = max(float(candidate.get("t") or 0.0) - args.pre_roll, 0.0)
    command = build_player_command(
        player,
        target_path,
        args.file_caching_ms,
        start_seconds=start_seconds,
    )
    print()
    print("Motion candidate")
    print(f"  Kind:     {candidate.get('kind')}")
    print(f"  Time:     {format_duration(candidate.get('t'))}")
    print(f"  Zone:     {motion_zone_label(candidate.get('zone'))}")
    print(f"  Mean:     {float(candidate.get('mean_diff') or 0.0):.2f}")
    print(f"  Changed:  {float(candidate.get('changed_pct') or 0.0):.2f}%")
    print("  Feedback: g=good, f=false positive, m=missed nearby, s=skip, q=quit")
    print("Player:", shlex.join(command))
    if not args.dry_run:
        subprocess.call(command)
    feedback = prompt_motion_feedback()
    if feedback is None:
        return None
    if feedback != "skip":
        record_motion_feedback(
            runtime_paths,
            candidate=candidate,
            feedback=feedback,
            profile_name=profile_name,
            session_dir=session_dir,
        )
    return feedback


def command_motion_tune(args: argparse.Namespace) -> int:
    config_path = args.config_file.expanduser()
    config = load_config(config_path)
    vision_profiles = config.get("vision_profiles", {})
    if not getattr(args, "target", None) and interactive_mode_enabled(args):
        selected_target = select_session_target(
            args,
            config,
            title="Choose a session to tune motion settings",
        )
        if not selected_target:
            print("no sessions found for motion tuning", file=sys.stderr)
            return 1
        args.target = Path(selected_target)

    try:
        session_dir = resolve_session_dir(
            args.recordings_dir.expanduser(),
            str(args.target) if getattr(args, "target", None) else None,
        )
    except FileNotFoundError as exc:
        print(exc, file=sys.stderr)
        return 1

    context = load_motion_tune_context(session_dir, config)
    runtime_paths = context["runtime_paths"]
    for line in motion_tune_summary_lines(session_dir, context):
        print(line)
    print()
    for line in motion_tune_legend_lines():
        print(line)
    print()

    source = export_source_for_session(session_dir)
    calibration_summary: dict | None = None
    if (
        source
        and context["motion_gate"]
        and (
            not interactive_mode_enabled(args)
            or prompt_yes_no(
                f"Run a {args.calibrate_seconds:g}s tail calibration at {args.motion_sample_interval:g}s?",
                default=True,
            )
        )
    ):
        calibration_samples = calibrate_motion_window(
            ffmpeg_bin=args.ffmpeg_bin,
            source_path=source.source_path,
            duration_seconds=args.calibrate_seconds,
            sample_interval=args.motion_sample_interval,
            motion_size=context["motion_size"],
            motion_zone=context["motion_zone"],
        )
        calibration_summary = summarize_motion_calibration(calibration_samples)
        for line in motion_calibration_summary_lines(calibration_summary):
            print(line)
        print()

    feedback_records: list[dict] = []
    candidate_groups = load_motion_candidates(
        session_dir,
        current_threshold=context["motion_threshold"],
        min_changed_pct=context["motion_min_changed_pct"],
        limit=max(args.limit, 1),
    )
    if not interactive_mode_enabled(args):
        print("Motion candidates")
        for heading, group_name in (
            ("Triggered", "triggered"),
            ("Near misses", "near_miss"),
        ):
            candidates = candidate_groups[group_name]
            if not candidates:
                continue
            print(f"{heading}:")
            for candidate in candidates:
                print(f"  {motion_candidate_summary_line(candidate)}")
        print()
        print("Run `field-replay motion-tune` interactively to review clips and record feedback.")
        return 0

    review_groups = [
        ("triggered", "Review triggered motion events?"),
        ("near_miss", "Review near-miss motion candidates?"),
    ]
    for group_name, prompt_text_value in review_groups:
        candidates = candidate_groups[group_name]
        if not candidates:
            continue
        if interactive_mode_enabled(args):
            if not prompt_yes_no(prompt_text_value, default=True):
                continue
            chosen_candidates = candidates
        else:
            chosen_candidates = candidates
        for candidate in chosen_candidates:
            feedback = run_motion_tune_candidate_review(
                args=args,
                session_dir=session_dir,
                runtime_paths=runtime_paths,
                profile_name=context.get("profile_name"),
                candidate=candidate,
            )
            if feedback is None:
                break
            if feedback != "skip":
                feedback_records.append(
                    {
                        "feedback": feedback,
                        "candidate": candidate,
                    }
                )
        print()

    if interactive_mode_enabled(args):
        while prompt_yes_no("Review a manual missed timestamp?", default=False):
            raw_time = prompt_text(
                "Missed timestamp (seconds or HH:MM:SS)",
            ).strip()
            missed_time = parse_seek_time_text(raw_time)
            if missed_time is None:
                print("Enter seconds like 5880.7 or HH:MM:SS like 01:38:01.")
                continue
            candidate = {
                "kind": "manual-missed",
                "t": missed_time,
                "zone": context["motion_zone"],
                "mean_diff": None,
                "changed_pct": None,
            }
            feedback = run_motion_tune_candidate_review(
                args=args,
                session_dir=session_dir,
                runtime_paths=runtime_paths,
                profile_name=context.get("profile_name"),
                candidate=candidate,
            )
            if feedback is None:
                break
            if feedback != "skip":
                feedback_records.append(
                    {
                        "feedback": feedback,
                        "candidate": candidate,
                    }
                )
        print()

    if not feedback_records:
        print("No motion feedback recorded in this tuning pass.")
        return 0

    suggestion = suggest_motion_setting_updates(
        feedback_records,
        current_threshold=context["motion_threshold"],
        current_consecutive=context["motion_consecutive"],
        calibration_summary=calibration_summary,
    )
    print("Motion feedback summary")
    print(f"  Good catches:     {suggestion['good']}")
    print(f"  False positives:  {suggestion['false_positive']}")
    print(f"  Missed events:    {suggestion['missed']}")
    print(
        "Suggested settings"
        f"\n  mean threshold:   {context['motion_threshold']:g} -> {suggestion['suggested_threshold']:g}"
        f"\n  consecutive hits: {context['motion_consecutive']} -> {suggestion['suggested_consecutive']}"
    )
    if suggestion["reasons"]:
        print("Why")
        for reason in suggestion["reasons"]:
            print(f"  {reason}")

    profile_name = context.get("profile_name")
    if (
        profile_name
        and profile_name in vision_profiles
        and interactive_mode_enabled(args)
        and prompt_yes_no(
            f"Apply these suggested settings to vision profile '{profile_name}'?",
            default=False,
        )
    ):
        vision_profiles[profile_name]["motion_threshold"] = suggestion[
            "suggested_threshold"
        ]
        vision_profiles[profile_name]["motion_consecutive"] = suggestion[
            "suggested_consecutive"
        ]
        config["vision_profiles"] = vision_profiles
        save_config(config_path, config)
        print(f"Updated vision profile: {profile_name}")
    return 0


def default_vision_prompt() -> str:
    return (
        "Find only clearly visible digit sequences on runner bibs, paper bib signs, "
        "or race number cards. Ignore timestamps and room signs. Do not guess or "
        "invent a number if the digits are partial, ambiguous, or missing."
    )


def prompt_seems_bib_focused(base_prompt: str) -> bool:
    prompt = base_prompt.lower()
    bib_markers = (
        "bib",
        "runner bib",
        "race number",
        "race numbers",
        "number card",
        "number cards",
        "bib number",
        "bib numbers",
        "pacer",
    )
    return any(marker in prompt for marker in bib_markers)


def single_frame_vision_prompt(base_prompt: str) -> str:
    bib_focused = prompt_seems_bib_focused(base_prompt)
    if bib_focused:
        example = '{"detections":["<bib-number>"]}'
    else:
        example = '{"detections":["white pickup right"]}'
    guidance = (
        "If the operator intent is bib tracking, return only exact bib numbers "
        "that are clearly visible on a person or race number card, and ignore "
        "unrelated background text. Do not copy the example number or invent a "
        "bib when none is visible. If the operator intent is general scene "
        "monitoring, return a descriptive label for each visible instance and use "
        "stable details such as color, type, and coarse position so distinct cars, "
        "people, and pets do not collapse into one label. Prefer a descriptive "
        "label such as 'white pickup right' or 'person red shirt left' over a "
        "bare class label like 'car' unless no better detail is visible."
    )
    return (
        "Use this detection task as the operator intent: "
        f"{base_prompt}\n"
        f"{guidance} Return only JSON in this exact shape: {example}. "
        'If none are clearly visible, return {"detections":[]}. '
        "Do not include explanations, markdown, or extra keys."
