    current_fps: int,
    current_input_format: str,
) -> dict | None:
    if not results:
        return None

    options: list[tuple[str, str]] = []
    default_value = None
    for index, item in enumerate(results, start=1):
        actual_fps = int(round(item["actual_fps"]))
        fmt = item["input_format"]
        fmt_label = "auto" if fmt == DEFAULT_VIDEO_INPUT_FORMAT else fmt
        requested_note = ""
        if not item["exact"]:
            requested_note = (
                f" (requested {item['requested_size']} @ {item['requested_fps']} fps)"
            )
        label = f"{item['actual_size']} @ {actual_fps} fps via {fmt_label}{requested_note}"
        value = str(index)
