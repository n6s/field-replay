    timeshift = session_dir / DEFAULT_TIMESHIFT_NAME
    if archive_mkv.exists():
        return ExportSource(session_dir, archive_mkv, "archive.mkv")
    if archive_mp4.exists():
        return ExportSource(session_dir, archive_mp4, "archive.mp4")
    if timeshift.exists():
        return ExportSource(session_dir, timeshift, "DVR timeshift")
    return None


def evidence_event_sources_for_session(session_dir: Path) -> list[tuple[str, Path]]:
    sources = [
        ("vision-scan", session_dir / "vision-scan" / "events.jsonl"),
        ("vision-live", session_dir / "vision-live" / "events.jsonl"),
    ]
    seen_paths = {path for _, path in sources}
    for scan_dir in sorted(session_dir.glob("vision-scan-*")):
        events_path = scan_dir / "events.jsonl"
        if events_path in seen_paths:
            continue
        sources.append((scan_dir.name, events_path))
        seen_paths.add(events_path)
    return [(label, path) for label, path in sources if path.exists()]


def load_evidence_matches_for_label(session_dir: Path, label: str) -> list[dict]:
    matches: list[dict] = []
    for source_label, source_path in evidence_event_sources_for_session(session_dir):
        for record in load_jsonl_records(source_path):
            if event_detection_label(record) != label:
                continue
            item = dict(record)
            item["_source"] = source_label
            item["_path"] = source_path
            matches.append(item)
    matches.sort(key=event_sort_key)
    return matches


