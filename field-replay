def parse_video_size(video_size: str) -> tuple[int | None, int | None]:
    if "x" not in video_size:
        return None, None
    try:
        width_text, height_text = video_size.lower().split("x", 1)
        return int(width_text), int(height_text)
    except ValueError:
        return None, None


def estimate_size_bytes(duration_seconds: float | None, total_mbps: float) -> int | None:
    if duration_seconds is None or duration_seconds <= 0:
        return None
    return int(duration_seconds * total_mbps * 1_000_000 / 8)


def storage_summary(path: Path) -> str:
    candidate = path.expanduser()
    target = candidate if candidate.exists() else candidate.parent
    try:
        usage = shutil.disk_usage(target)
    except FileNotFoundError:
        return f"{candidate} (path does not exist yet)"
    return f"{candidate} ({format_bytes(usage.free)} free)"


def v4l_id_aliases() -> dict[str, Path]:
    by_id_dir = Path("/dev/v4l/by-id")
    aliases: dict[str, Path] = {}
    if not by_id_dir.exists():
        return aliases

    for item in sorted(by_id_dir.iterdir()):
        try:
            resolved = item.resolve()
        except OSError:
            continue
        aliases[str(resolved)] = item
    return aliases


def v4l_persistent_alias(device_path: str) -> str | None:
    try:
        resolved = str(Path(device_path).resolve())
    except OSError:
        return None
    alias_path = v4l_id_aliases().get(resolved)
    if alias_path:
        return str(alias_path)
    return None


def list_video_devices() -> list[VideoDevice]:
    devices: list[VideoDevice] = []
    aliases = v4l_id_aliases()
    sysfs_root = Path("/sys/class/video4linux")
    if not sysfs_root.exists():
        return devices

    for entry in sorted(sysfs_root.iterdir()):
        device_path = Path("/dev") / entry.name
        if not device_path.exists():
            continue
        name_path = entry / "name"
        label = entry.name
        if name_path.exists():
            label = name_path.read_text().strip() or label
        alias_path = aliases.get(str(device_path.resolve()))
        full_label = f"{device_path} - {label}"
        selected_path = str(device_path)
        if alias_path:
            selected_path = str(alias_path)
            full_label = f"{alias_path} -> {device_path} - {label}"
        devices.append(VideoDevice(path=selected_path, label=full_label))
    return devices

def build_ffmpeg_command(paths: SessionPaths, args: argparse.Namespace) -> list[str]:
    gop = effective_gop(args)
    command = [
        args.ffmpeg_bin,
        "-hide_banner",
        "-stats",
        "-thread_queue_size",
        str(args.thread_queue_size),
        "-fflags",
        "+genpts",
    ]

    if is_rtsp_source(args):
        command.extend(["-use_wallclock_as_timestamps", "1"])
        if args.rtsp_transport != "auto":
            command.extend(["-rtsp_transport", args.rtsp_transport])
        command.extend(["-i", args.rtsp_url])
    else:
        command.extend(
            [
                "-f",
                "v4l2",
                "-framerate",
                str(args.framerate),
                "-video_size",
                args.video_size,
            ]
        )

        if args.video_input_format != DEFAULT_VIDEO_INPUT_FORMAT:
            command.extend(["-input_format", args.video_input_format])

        if args.timestamp_source == "device":
            command.extend(["-timestamps", args.timestamps])
        else:
            command.extend(["-use_wallclock_as_timestamps", "1"])

        command.extend(["-i", args.device])

    if uses_alsa_audio_input(args):
        command.extend(
            [
                "-thread_queue_size",
                str(args.audio_thread_queue_size),
                "-use_wallclock_as_timestamps",
                "1",
                "-f",
                "alsa",
                "-sample_rate",
                str(args.audio_input_rate),
                "-channels",
                str(args.audio_input_channels),
                "-i",
                args.audio_device,
            ]
        )

    command.extend(
        [
            "-map",
            "0:v:0",
        ]
    )

    if args.audio:
        if is_rtsp_source(args):
            command.extend(["-map", "0:a:0?"])
        else:
            command.extend(["-map", "1:a:0"])

    if uses_video_passthrough(args):
        command.extend(["-c:v", "copy"])
    else:
        command.extend(
            [
                "-vf",
                build_video_filter(args),
                "-fps_mode",
                "cfr",
                "-c:v",
                args.encoder,
                "-preset",
                args.preset,
                "-pix_fmt",
                "yuv420p",
                "-g",
                str(gop),
                "-keyint_min",
                str(gop),
            ]
        )

        if args.video_bitrate:
            command.extend(["-b:v", args.video_bitrate])
        if args.maxrate:
            command.extend(["-maxrate", args.maxrate])
        if args.bufsize:
            command.extend(["-bufsize", args.bufsize])

    if args.audio:
        command.extend(
            [
                "-af",
                build_audio_filter(args),
                "-c:a",
                args.audio_encoder,
                "-b:a",
                args.audio_bitrate,
                "-ac",
                str(args.audio_channels),
                "-ar",
                str(args.audio_sample_rate),
            ]
        )

    command.extend(
        [
            "-f",
            "mpegts",
            "-mpegts_flags",
            "+initial_discontinuity",
            "-muxdelay",
            "0",
            "-muxpreload",
            "0",
            str(paths.timeshift_path.name),
        ]
    )
    return command


def build_video_filter(args: argparse.Namespace) -> str:
    filters = [
        f"fps={args.framerate}",
        "settb=AVTB",
        f"setpts=N/({args.framerate}*TB)",
    ]
    if getattr(args, "video_timestamp", DEFAULT_VIDEO_TIMESTAMP_ENABLED):
        filters.append(
            "drawtext="
            "text='%{localtime\\:%Y-%m-%d %X}':"
            "x=20:y=h-th-20:"
            "box=1:boxcolor=0x00000099:boxborderw=10:"
            "fontcolor=white:fontsize=24:borderw=2"
        )
    return ",".join(filters)


def build_audio_filter(args: argparse.Namespace) -> str:
    filters = ["aresample=async=1:first_pts=0"]
    if abs(args.audio_gain_db) >= 0.05:
        filters.append(f"volume={args.audio_gain_db}dB")
    return ",".join(filters)


def choose_player(preferred: str | None) -> str | None:
    if preferred:
        preferred_path = Path(preferred).expanduser()
        if preferred_path.is_file():
            return str(preferred_path)
        return shutil.which(preferred)
    for name in ("mpv", "vlc", "ffplay", "cvlc"):
        resolved = shutil.which(name)
        if resolved:
            return resolved
    return None


def list_alsa_cards() -> list[tuple[str, str, str]]:
    cards_path = Path("/proc/asound/cards")
    if not cards_path.exists():
        return []

    cards: list[tuple[str, str, str]] = []
    lines = cards_path.read_text().splitlines()
    for index, line in enumerate(lines):
        stripped = line.strip()
        if not stripped or "[" not in stripped or "]" not in stripped:
            continue
        parts = stripped.split()
        card_index = parts[0]
        card_id = stripped.split("[", 1)[1].split("]", 1)[0].strip()
        description = ""
        if index + 1 < len(lines):
            description = lines[index + 1].strip()
        cards.append((card_index, card_id, description))
    return cards


def parse_hw_device(device_name: str) -> tuple[str, str] | None:
    if not device_name.startswith("hw:") or "," not in device_name:
        return None
    card_token, pcm_device = device_name[3:].split(",", 1)
    return card_token, pcm_device


def list_alsa_capture_devices() -> list[AudioDevice]:
    cards = {index: (card_id, desc) for index, card_id, desc in list_alsa_cards()}
    pcm_path = Path("/proc/asound/pcm")
    if not pcm_path.exists():
        return []

    devices: list[AudioDevice] = []
    for line in pcm_path.read_text().splitlines():
        stripped = line.strip()
        if not stripped or ": capture" not in stripped:
            continue
        card_and_pcm = stripped.split(":", 1)[0]
        if "-" not in card_and_pcm:
            continue
        card_index_raw, pcm_device_raw = card_and_pcm.split("-", 1)
        card_index = str(int(card_index_raw))
        pcm_device = str(int(pcm_device_raw))
        card_id, description = cards.get(card_index, (card_index, ""))
        label = f"hw:{card_id},{pcm_device}"
        if description:
            label += f" - {description}"
        devices.append(AudioDevice(device=f"hw:{card_id},{pcm_device}", label=label))
    return devices


def alsa_device_exists(device_name: str) -> bool:
    parsed = parse_hw_device(device_name)
    if not parsed:
        return False

    requested_card, requested_pcm = parsed
    cards = list_alsa_cards()
    valid_card_tokens = {
        card_token
        for index, card_token, _ in cards
        if requested_card in {index, card_token}
    }
    if not valid_card_tokens:
        return False

    for device in list_alsa_capture_devices():
        device_card, device_pcm = parse_hw_device(device.device) or ("", "")
        if device_pcm == requested_pcm and device_card in valid_card_tokens:
            return True
    return False


def detect_supported_encoders(ffmpeg_bin: str) -> tuple[str | None, set[str]]:
    ffmpeg_path = shutil.which(ffmpeg_bin)
    if not ffmpeg_path:
        return None, set()

    result = subprocess.run(
        [ffmpeg_path, "-hide_banner", "-encoders"],
        capture_output=True,
        text=True,
        check=False,
    )
    encoders: set[str] = set()
    for line in result.stdout.splitlines():
        parts = line.split()
        if len(parts) >= 2 and parts[0][0] in {"V", "A", "S"}:
            encoders.add(parts[1])
    return ffmpeg_path, encoders


def encoder_smoke_test(
    ffmpeg_path: str, encoder: str, *, video_size: str = "640x480", framerate: int = 30
) -> bool:
    command = [
        ffmpeg_path,
        "-hide_banner",
        "-loglevel",
        "error",
        "-f",
        "lavfi",
        "-i",
        f"nullsrc=s={video_size}:r={framerate}",
        "-frames:v",
        "1",
        "-an",
        "-c:v",
        encoder,
        "-f",
        "null",
        "-",
    ]
    ok, _ = run_ffmpeg_probe(command, timeout_seconds=8.0)
    return ok


def detect_supported_filters(ffmpeg_bin: str) -> tuple[str | None, set[str]]:
    ffmpeg_path = shutil.which(ffmpeg_bin)
    if not ffmpeg_path:
        return None, set()

    result = subprocess.run(
        [ffmpeg_path, "-hide_banner", "-filters"],
        capture_output=True,
        text=True,
        check=False,
    )
    filters: set[str] = set()
    for line in result.stdout.splitlines():
        parts = line.split()
        if len(parts) >= 3 and "->" in parts[2]:
            filters.add(parts[1])
    return ffmpeg_path, filters


def ffprobe_duration_seconds(target_path: Path) -> float | None:
    ffprobe_bin = shutil.which("ffprobe")
    if not ffprobe_bin:
        return None
    result = subprocess.run(
        [
            ffprobe_bin,
            "-v",
            "error",
            "-show_entries",
            "format=duration",
            "-of",
            "default=noprint_wrappers=1:nokey=1",
            str(target_path),
        ],
        capture_output=True,
        text=True,
        check=False,
    )
    if result.returncode != 0:
        return None
    try:
        duration = float(result.stdout.strip())
    except ValueError:
        return None
    return duration if duration >= 0 else None


def resolve_encoder(
    ffmpeg_path: str | None, supported_encoders: set[str], requested: str
) -> str | None:
    if not ffmpeg_path:
        return None
    if requested in supported_encoders and encoder_smoke_test(ffmpeg_path, requested):
        return requested
    for candidate in ("h264_nvenc", "libx264", "h264_v4l2m2m", "h264_vaapi", "mpeg4"):
        if candidate in supported_encoders and encoder_smoke_test(ffmpeg_path, candidate):
            return candidate
    return None


def normalize_video_settings(
    args: argparse.Namespace,
    *,
    supported_filters: set[str] | None = None,
) -> list[str]:
    warnings: list[str] = []
    if uses_video_passthrough(args):
        if args.video_timestamp:
            args.video_timestamp = False
            warnings.append(
                "video passthrough mode cannot burn a wall-clock timestamp; disabling video timestamp overlay"
            )
        return warnings

    if supported_filters is not None and args.video_timestamp and "drawtext" not in supported_filters:
        args.video_timestamp = False
        warnings.append(
            "ffmpeg drawtext filter is unavailable; disabling video timestamp overlay"
        )
    return warnings


def v4l2ctl_pixel_format_alias(code: str) -> str:
    aliases = {
        "MJPG": "mjpeg",
        "YUYV": "yuyv422",
        "UYVY": "uyvy422",
        "NV12": "nv12",
    }
    return aliases.get(code.upper(), code.lower())


def list_v4l2_modes(device: str) -> list[V4L2Mode]:
    v4l2_ctl = shutil.which("v4l2-ctl")
    if not v4l2_ctl:
        return []

    result = subprocess.run(
        [v4l2_ctl, "-d", device, "--list-formats-ext"],
        capture_output=True,
        text=True,
        check=False,
    )
    if result.returncode != 0:
        return []

    modes: list[V4L2Mode] = []
    current_format = DEFAULT_VIDEO_INPUT_FORMAT
    current_size = None
    format_pattern = re.compile(r"\[\d+\]:\s+'([^']+)'")
    size_pattern = re.compile(r"Size:\s+Discrete\s+(\d+x\d+)")
    fps_pattern = re.compile(r"\(([\d.]+)\s+fps\)")
    for line in result.stdout.splitlines():
        format_match = format_pattern.search(line)
        if format_match:
            current_format = v4l2ctl_pixel_format_alias(format_match.group(1))
            current_size = None
            continue
        size_match = size_pattern.search(line)
        if size_match:
            current_size = size_match.group(1)
            continue
        fps_match = fps_pattern.search(line)
        if fps_match and current_size:
            try:
                framerate = int(round(float(fps_match.group(1))))
            except ValueError:
                continue
            modes.append(
                V4L2Mode(
                    input_format=current_format,
                    video_size=current_size,
                    framerate=framerate,
                )
            )

    unique: list[V4L2Mode] = []
    seen: set[tuple[str, str, int]] = set()
    for mode in modes:
        key = (mode.input_format, mode.video_size, mode.framerate)
        if key in seen:
            continue
        seen.add(key)
        unique.append(mode)
    return unique


def run_ffmpeg_probe(command: Sequence[str], timeout_seconds: float = 8.0) -> tuple[bool, str]:
    try:
        result = subprocess.run(
            list(command),
            capture_output=True,
            text=True,
            check=False,
            timeout=timeout_seconds,
        )
    except (OSError, subprocess.TimeoutExpired) as exc:
        return False, str(exc)

    output = "\n".join(part for part in (result.stdout, result.stderr) if part).strip()
    return result.returncode == 0, output


def extract_probe_video_details(output: str) -> tuple[str | None, float | None]:
    video_size = None
    fps = None
    size_match = re.search(r"Video:\s.*?,\s(\d+x\d+)", output)
    if size_match:
        video_size = size_match.group(1)

    fps_match = re.search(r",\s([0-9]+(?:\.[0-9]+)?)\sfps,", output)
    if fps_match:
        fps = float(fps_match.group(1))
    else:
        changed_match = re.search(
            r"time per frame from 1/([0-9]+) to 1/([0-9]+)", output
        )
        if changed_match:
            numerator = float(changed_match.group(2))
            if numerator:
                fps = numerator
    return video_size, fps


def extract_probe_video_codec(output: str) -> str | None:
    codec_match = re.search(r"Video:\s([a-zA-Z0-9_]+)", output)
    if codec_match:
        return codec_match.group(1).lower()
    return None


def summarize_probe_failure(output: str) -> str | None:
    for line in reversed(output.splitlines()):
        stripped = line.strip()
        if stripped and "frame=" not in stripped:
            return stripped
    return None


def probe_video_mode(
    ffmpeg_bin: str,
    device: str,
    video_size: str,
    framerate: int,
    input_format: str,
) -> dict:
    command = [
        ffmpeg_bin,
        "-hide_banner",
        "-loglevel",
        "info",
        "-f",
        "v4l2",
    ]
    if input_format != DEFAULT_VIDEO_INPUT_FORMAT:
        command.extend(["-input_format", input_format])
    command.extend(
        [
            "-framerate",
            str(framerate),
            "-video_size",
            video_size,
            "-i",
            device,
            "-frames:v",
            "1",
            "-f",
            "null",
            "-",
        ]
    )
    ok, output = run_ffmpeg_probe(command)
    actual_size, actual_fps = extract_probe_video_details(output)
    actual_codec = extract_probe_video_codec(output)
    exact = ok and actual_size == video_size and (
        actual_fps is None or abs(actual_fps - framerate) < 0.5
    )
    return {
        "ok": ok,
        "input_format": input_format,
        "requested_size": video_size,
        "requested_fps": framerate,
        "actual_size": actual_size or video_size,
        "actual_fps": actual_fps or float(framerate),
        "actual_codec": actual_codec or input_format,
        "exact": exact,
        "output": output,
    }


def video_probe_candidates(
    device: str, video_size: str, framerate: int, input_format: str
) -> list[tuple[str, int, str]]:
    advertised_modes = list_v4l2_modes(device)
    if advertised_modes:
        requested_width, requested_height = parse_video_size(video_size)

        def sort_key(mode: V4L2Mode) -> tuple[int, float, int, int, int]:
            width, height = parse_video_size(mode.video_size)
            area = (width or 0) * (height or 0)
            exact_match = int(
                mode.video_size == video_size
                and mode.framerate == framerate
                and mode.input_format == input_format
            )
            fps_delta = abs(mode.framerate - framerate)
            if requested_width and requested_height and width and height:
                pixel_delta = abs((width * height) - (requested_width * requested_height))
            else:
                pixel_delta = float("inf")
            preferred_format = int(mode.input_format == input_format)
            return (exact_match, preferred_format, -fps_delta, area, -pixel_delta)

        ordered = sorted(advertised_modes, key=sort_key, reverse=True)
        return [(mode.video_size, mode.framerate, mode.input_format) for mode in ordered]

    sizes = [video_size, *[size for size in COMMON_VIDEO_SIZES if size != video_size]]
    fps_values = [framerate, *[fps for fps in COMMON_FRAME_RATES if fps != framerate]]
    formats = [
        input_format,
        *[fmt for fmt in COMMON_VIDEO_INPUT_FORMATS if fmt != input_format],
    ]
    candidates: list[tuple[str, int, str]] = []
    for fmt in formats:
        for size in sizes:
            for fps in fps_values:
                triple = (size, fps, fmt)
                if triple not in candidates:
                    candidates.append(triple)
    return candidates


def choose_video_profile_settings(
    ffmpeg_bin: str,
    device: str,
    current_size: str,
    current_fps: int,
    current_input_format: str,
    *,
    stop_on_exact: bool = True,
) -> tuple[str, int, str, list[dict], str | None]:
    successful: list[dict] = []
    seen_actual: set[tuple[str, int, str]] = set()
    failure_reason = None
    for size, fps, input_format in video_probe_candidates(
        device, current_size, current_fps, current_input_format
    ):
        result = probe_video_mode(ffmpeg_bin, device, size, fps, input_format)
        if not result["ok"]:
            failure_reason = summarize_probe_failure(result["output"]) or failure_reason
            continue
        actual_key = (
            result["actual_size"],
            int(round(result["actual_fps"])),
            result["input_format"],
        )
        if actual_key in seen_actual:
            continue
        successful.append(result)
        seen_actual.add(actual_key)
        if stop_on_exact and result["exact"]:
            return size, fps, input_format, successful, failure_reason
        if stop_on_exact and len(successful) >= 4:
            break

    if not successful:
        return current_size, current_fps, current_input_format, [], failure_reason

    def video_score(item: dict) -> tuple[float, int]:
        requested_pixels = int(current_size.split("x")[0]) * int(current_size.split("x")[1])
        actual_width, actual_height = [int(part) for part in item["actual_size"].split("x")]
        actual_pixels = actual_width * actual_height
        fps_score = min(item["actual_fps"], current_fps)
        pixel_score = min(actual_pixels, requested_pixels) / max(requested_pixels, 1)
        return (fps_score + pixel_score, actual_pixels)

    best = max(successful, key=video_score)
    return (
        best["actual_size"],
        int(round(best["actual_fps"])),
        best["input_format"],
        successful,
        failure_reason,
    )


def probe_audio_input(
    ffmpeg_bin: str, device: str, sample_rate: int, channels: int
) -> dict:
    command = [
        ffmpeg_bin,
        "-hide_banner",
        "-loglevel",
        "info",
        "-f",
        "alsa",
        "-sample_rate",
        str(sample_rate),
        "-channels",
        str(channels),
        "-i",
        device,
        "-t",
        "0.2",
        "-f",
        "null",
        "-",
    ]
    ok, output = run_ffmpeg_probe(command)
    return {
        "ok": ok,
        "sample_rate": sample_rate,
        "channels": channels,
        "output": output,
    }


def choose_audio_profile_settings(
    ffmpeg_bin: str, device: str, current_rate: int, current_channels: int
) -> tuple[int, int, list[dict], str | None]:
    candidates = [
        (current_rate, current_channels),
        *[
            pair
            for pair in COMMON_AUDIO_INPUTS
            if pair != (current_rate, current_channels)
        ],
    ]
    successes: list[dict] = []
    failure_reason = None
    for sample_rate, channels in candidates:
        result = probe_audio_input(ffmpeg_bin, device, sample_rate, channels)
        if result["ok"]:
            successes.append(result)
            if sample_rate == current_rate and channels == current_channels:
                return sample_rate, channels, successes, failure_reason
            if len(successes) >= 3:
                break
        else:
            failure_reason = summarize_probe_failure(result["output"]) or failure_reason

    if not successes:
        return current_rate, current_channels, [], failure_reason

    best = max(successes, key=lambda item: (item["channels"], item["sample_rate"]))
    return best["sample_rate"], best["channels"], successes, failure_reason


def print_video_probe_results(results: Sequence[dict]) -> None:
