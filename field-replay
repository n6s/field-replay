        print("No working video mode was detected with the built-in probe.")
        return
    print("Detected video modes")
    for index, item in enumerate(results, start=1):
        actual_fps = int(round(item["actual_fps"]))
        note = ""
        if not item["exact"]:
            note = f" (requested {item['requested_size']} @ {item['requested_fps']} fps)"
        fmt = item["input_format"]
        fmt_label = "auto" if fmt == DEFAULT_VIDEO_INPUT_FORMAT else fmt
        print(f"  {index}. {item['actual_size']} @ {actual_fps} fps via {fmt_label}{note}")


def choose_video_probe_result(
    results: Sequence[dict],
    *,
