def resolve_timelapse_spec(
    args: argparse.Namespace, session_metadata: dict, source_path: Path
) -> TimelapseSpec | None:
    if args.timelapse_speed is None:
        return None
    speed = args.timelapse_speed
    output_fps = args.timelapse_output_fps
    input_fps = args.timelapse_input_fps
    if input_fps is None:
        metadata_fps = session_metadata.get("framerate")
        if isinstance(metadata_fps, (int, float)) and metadata_fps > 0:
            input_fps = float(metadata_fps)
    if input_fps is None:
        input_fps = probe_media_frame_rate(args.ffmpeg_bin, source_path)
    if input_fps is None:
        input_fps = output_fps
    frame_skip = max(1, int(input_fps * speed / output_fps))
    return TimelapseSpec(
        speed=speed,
        output_fps=output_fps,
        input_fps=input_fps,
        frame_skip=frame_skip,
    )


def validate_timelapse_args(args: argparse.Namespace) -> str | None:
    if args.timelapse_speed is not None and args.timelapse_speed <= 0:
        return "--timelapse speed must be greater than zero"
    if args.timelapse_output_fps <= 0:
        return "--timelapse-output-fps must be greater than zero"
    if args.timelapse_input_fps is not None and args.timelapse_input_fps <= 0:
        return "--timelapse-input-fps must be greater than zero"
    return None


def build_player_command(
    player: str,
    target_path: Path,
    file_caching_ms: int,
    start_seconds: float | None = None,
) -> list[str]:
    player_name = Path(player).name
    if player_name == "ffplay":
        command = [player]
        if start_seconds is not None and start_seconds > 0:
            command.extend(["-ss", f"{start_seconds:.1f}"])
        command.append(str(target_path))
        return command
    if player_name == "mpv":
        cache_seconds = max(file_caching_ms / 1000.0, 0.1)
        command = [
            player,
            "--hwdec=no",
            "--cache=yes",
            f"--demuxer-readahead-secs={cache_seconds:.1f}",
            f"--audio-buffer={cache_seconds:.1f}",
            "--cache-pause=no",
            "--keep-open=yes",
            "--force-seekable=yes",
            "--hr-seek=no",
        ]
        if start_seconds is not None and start_seconds > 0:
            command.append(f"--start={start_seconds:.1f}")
        command.append(str(target_path))
        return command
    command = [
        player,
        "--avcodec-hw=none",
        f"--file-caching={file_caching_ms}",
    ]
    if start_seconds is not None and start_seconds > 0:
        command.append(f"--start-time={start_seconds:.1f}")
    command.append(str(target_path))
    return command


def choose_image_viewer(preferred: str | None) -> str | None:
    if preferred:
        preferred_path = Path(preferred).expanduser()
        if preferred_path.is_file():
            return str(preferred_path)
        return shutil.which(preferred)
    return shutil.which("eog")


def build_image_viewer_command(viewer: str, image_paths: Sequence[Path]) -> list[str]:
    viewer_name = Path(viewer).name
    command = [viewer]
    if viewer_name == "eog":
        command.append("--single-window")
    command.extend(str(path) for path in image_paths)
    return command


def launch_background_viewer(command: Sequence[str]) -> subprocess.Popen[bytes]:
