def resolve_export_encoder(
    supported_encoders: set[str], session_metadata: dict
) -> tuple[str | None, str, str]:
    session_encoder = session_metadata.get("encoder")
    session_preset = str(session_metadata.get("preset") or "fast")
    if session_encoder and session_encoder in supported_encoders:
        return session_encoder, session_preset, "matched session encoder"
    if "h264_nvenc" in supported_encoders:
        return "h264_nvenc", "fast", "hardware export encoder available"
    if "libx264" in supported_encoders:
        return "libx264", "medium", "software export fallback"
    fallback = None
    for candidate in ("h264_vaapi", "h264_v4l2m2m", "mpeg4"):
        if candidate in supported_encoders:
            fallback = candidate
            break
    if fallback:
        default_preset = "fast" if fallback.startswith("h264_") else "medium"
        return fallback, default_preset, "best available fallback"
    return None, "medium", "no supported export encoder"


def build_export_command(
    ffmpeg_bin: str,
    source_path: Path,
    output_path: Path,
    preset_name: str,
    video_encoder: str,
    encoder_preset: str,
) -> list[str]:
    preset = EXPORT_PRESETS[preset_name]
    video_bitrate_mbps = preset["video_bitrate_mbps"]
    audio_bitrate_kbps = preset["audio_bitrate_kbps"]
    maxrate_mbps = max(video_bitrate_mbps * 4 / 3, video_bitrate_mbps)
    bufsize_mbps = maxrate_mbps * 2
    command = [
        ffmpeg_bin,
        "-hide_banner",
        "-stats",
        "-y",
        "-i",
        str(source_path),
    ]
    if preset["scale"]:
        command.extend(["-vf", f"scale={preset['scale']}"])
    command.extend(
        [
            "-c:v",
            video_encoder,
            "-preset",
            encoder_preset,
            "-b:v",
            f"{video_bitrate_mbps:g}M",
            "-maxrate",
            f"{maxrate_mbps:g}M",
            "-bufsize",
            f"{bufsize_mbps:g}M",
            "-pix_fmt",
            "yuv420p",
            "-c:a",
            "aac",
            "-b:a",
            f"{audio_bitrate_kbps}k",
            "-movflags",
            "+faststart",
            str(output_path),
        ]
    )
    return command


def preset_total_mbps(preset_name: str) -> float:
    preset = EXPORT_PRESETS[preset_name]
    return preset["video_bitrate_mbps"] + (preset["audio_bitrate_kbps"] / 1000.0)


